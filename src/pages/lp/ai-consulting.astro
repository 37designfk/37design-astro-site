---
import LPLayout from '../../layouts/LPLayout.astro';
import LPFooter from '../../components/lp/LPFooter.astro';
---

<LPLayout
  title="Web AI顧問｜AIで、売上が変わる。｜37Design"
  description="最新のAI技術と専属のWEBコンサルタントが融合。サイト改善・SEO分析・コンテンツ戦略・広告最適化を月額2万円から。73サイト管理、28社以上の支援実績。"
  image="https://37design.co.jp/images/ogp.png"
  dashboardSlug="37design-ai-consulting"
>
  <style>
    /* ========================================
       AI Consulting LP - Dark Theme Overrides
       ======================================== */
    body {
      background-color: #0a0a0a !important;
      color: #ffffff !important;
    }

    /* Custom Scrollbar */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #0a0a0a; }
    ::-webkit-scrollbar-thumb { background: #27272a; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #3f3f46; }

    /* Glassmorphism */
    .glass-panel {
      background: rgba(25, 25, 25, 0.4);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .glass-panel-hover {
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .glass-panel-hover:hover {
      background: rgba(35, 35, 35, 0.6);
      border: 1px solid rgba(139, 92, 246, 0.3);
      transform: translateY(-4px);
      box-shadow: 0 10px 40px -10px rgba(139, 92, 246, 0.15);
    }

    /* Gradient Text Glow */
    .text-glow {
      text-shadow: 0 0 40px rgba(139, 92, 246, 0.5);
    }

    /* FAQ accordion */
    details > summary { list-style: none; }
    details > summary::-webkit-details-marker { display: none; }
    details[open] summary ~ * {
      animation: sweep .3s ease-in-out;
    }
    @keyframes sweep {
      0%   { opacity: 0; margin-top: -10px; }
      100% { opacity: 1; margin-top: 0; }
    }

    /* Nav blur mask */
    .nav-blur {
      mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
      -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    }

    /* Blob animation */
    @keyframes blob {
      0%   { transform: translate(0px, 0px) scale(1); }
      33%  { transform: translate(30px, -50px) scale(1.1); }
      66%  { transform: translate(-20px, 20px) scale(0.9); }
      100% { transform: translate(0px, 0px) scale(1); }
    }
    .animate-blob { animation: blob 10s infinite; }

    /* Fade in up */
    @keyframes fadeInUpLP {
      0%   { opacity: 0; transform: translateY(20px); }
      100% { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in-up {
      animation: fadeInUpLP 1s ease-out forwards;
    }

    /* CTA sweep */
    @keyframes sweep-right {
      0%   { transform: translateX(-100%); }
      100% { transform: translateX(50%); }
    }

    /* Mesh background */
    .bg-mesh {
      background:
        radial-gradient(at 40% 20%, hsla(250,50%,20%,0.2) 0px, transparent 50%),
        radial-gradient(at 80% 0%, hsla(280,60%,20%,0.2) 0px, transparent 50%),
        radial-gradient(at 0% 50%, hsla(220,60%,20%,0.2) 0px, transparent 50%);
    }

    /* Font stack for this LP */
    .font-en { font-family: 'Plus Jakarta Sans', sans-serif; }
    .font-jp { font-family: 'Noto Sans JP', sans-serif; }
  </style>

  <!-- Google Fonts for this LP -->
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link slot="head" href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&family=Plus+Jakarta+Sans:wght@200;400;600;800&display=swap" rel="stylesheet" />

  <!-- Phosphor Icons -->
  <script is:inline src="https://unpkg.com/@phosphor-icons/web"></script>

  <!-- Ambient Background Lighting -->
  <div class="fixed inset-0 z-[-1] bg-mesh pointer-events-none"></div>
  <div class="fixed top-[-20%] left-[-10%] w-[50vw] h-[50vw] rounded-full bg-[#4f46e5]/10 blur-[120px] mix-blend-screen animate-blob pointer-events-none"></div>
  <div class="fixed bottom-[-20%] right-[-10%] w-[60vw] h-[60vw] rounded-full bg-[#9333ea]/10 blur-[150px] mix-blend-screen animate-blob pointer-events-none" style="animation-delay: 2s;"></div>

  <!-- Navigation -->
  <header class="fixed top-0 w-full z-50 pt-6 pb-12 px-6 lg:px-12 nav-blur flex justify-between items-center transition-all duration-300 pointer-events-none">
    <div class="glass-panel px-6 py-3 rounded-full flex items-center gap-3 pointer-events-auto">
      <div class="w-6 h-6 rounded bg-gradient-to-br from-[#4f46e5] to-[#ec4899] flex items-center justify-center shadow-[0_0_15px_rgba(139,92,246,0.5)]">
        <span class="text-white font-en font-bold text-xs">37</span>
      </div>
      <span class="font-en font-bold tracking-widest text-sm uppercase">Design</span>
    </div>

    <div class="pointer-events-auto hidden md:block">
      <div class="relative group">
        <div class="absolute -inset-1 bg-gradient-to-r from-[#2563eb] via-[#9333ea] to-[#ec4899] rounded-full blur opacity-30 group-hover:opacity-75 transition duration-500"></div>
        <a href="#contact" class="relative block px-6 py-3 bg-[#121212] border border-white/10 rounded-full text-sm font-jp font-medium transition-all group-hover:text-white">
          無料相談を予約
        </a>
      </div>
    </div>
  </header>

  <!-- ========== HERO ========== -->
  <section class="relative min-h-screen flex items-center justify-center px-6 pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0 flex justify-center items-center opacity-20 z-[-1] pointer-events-none">
      <div class="w-[1px] h-full bg-gradient-to-b from-transparent via-white to-transparent"></div>
      <div class="h-[1px] w-full absolute bg-gradient-to-r from-transparent via-white to-transparent"></div>
    </div>

    <div class="max-w-5xl mx-auto text-center relative z-10 w-full">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/10 bg-white/5 backdrop-blur-md mb-8 animate-fade-in-up" style="animation-delay: 0.1s;">
        <span class="flex h-2 w-2 relative">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#ec4899] opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[#ec4899]"></span>
        </span>
        <span class="text-xs font-en font-semibold tracking-widest text-zinc-300">WEB AI CONSULTING FOR B2B</span>
      </div>

      <h1 class="text-5xl md:text-7xl lg:text-[6rem] font-jp font-black leading-[1.1] tracking-tight mb-8 animate-fade-in-up" style="animation-delay: 0.2s;">
        <span class="block text-zinc-100">AIで、</span>
        <span class="block mt-2 bg-clip-text text-transparent bg-gradient-to-r from-[#2563eb] via-[#9333ea] to-[#ec4899] text-glow">売上が変わる。</span>
      </h1>

      <p class="text-zinc-400 text-lg md:text-xl font-jp tracking-wide max-w-2xl mx-auto leading-loose mb-12 animate-fade-in-up" style="animation-delay: 0.3s;">
        最新のAI技術と専属のWEBコンサルタントが融合。<br class="hidden md:block" />
        あなたのビジネスをデジタル領域で次のレベルへ引き上げる、<br class="hidden md:block" />
        まったく新しいパートナーシップ。
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 animate-fade-in-up" style="animation-delay: 0.4s;">
        <div class="relative group w-full sm:w-auto cursor-pointer">
          <div class="absolute -inset-1 bg-gradient-to-r from-[#2563eb] via-[#9333ea] to-[#ec4899] rounded-full blur opacity-60 group-hover:opacity-100 transition duration-500 group-hover:duration-200"></div>
          <a href="#contact" class="flex relative items-center justify-center w-full px-8 py-5 bg-[#0a0a0a] rounded-full text-white font-jp font-bold text-lg transition-transform group-hover:scale-[0.98]">
            無料WEB診断を申し込む
            <i class="ph ph-arrow-right ml-3 text-xl transition-transform group-hover:translate-x-1"></i>
          </a>
        </div>
        <p class="text-sm text-zinc-500 font-jp">※毎月限定5社まで</p>
      </div>
    </div>
  </section>

  <!-- ========== PAIN POINTS ========== -->
  <section class="py-32 px-6 relative border-t border-white/5">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20">
        <h2 class="text-3xl md:text-4xl font-jp font-bold bg-clip-text text-transparent bg-gradient-to-r from-zinc-100 to-zinc-500 inline-block mb-4">こんなお悩みありませんか？</h2>
        <p class="text-zinc-400 font-jp tracking-wide">WEB運用に関する多くの経営者が抱える課題。私たちなら解決できます。</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="glass-panel rounded-3xl p-8 glass-panel-hover group relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-[#2563eb]/10 rounded-full blur-3xl group-hover:bg-[#2563eb]/20 transition-all"></div>
          <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mb-6 text-[#2563eb] text-3xl group-hover:scale-110 transition-transform">
            <i class="ph ph-browser"></i>
          </div>
          <h3 class="text-xl font-jp font-bold mb-4 text-zinc-100">サイトの更新が止まっている</h3>
          <p class="text-zinc-400 font-jp leading-relaxed text-sm">
            作るだけで満足してしまい、最新の情報や実績が反映されていない。担当者が退職してしまい、誰も触れない状態に。
          </p>
        </div>

        <div class="glass-panel rounded-3xl p-8 glass-panel-hover group relative overflow-hidden mt-0 md:mt-8">
          <div class="absolute top-0 right-0 w-32 h-32 bg-[#9333ea]/10 rounded-full blur-3xl group-hover:bg-[#9333ea]/20 transition-all"></div>
          <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mb-6 text-[#9333ea] text-3xl group-hover:scale-110 transition-transform">
            <i class="ph ph-trend-down"></i>
          </div>
          <h3 class="text-xl font-jp font-bold mb-4 text-zinc-100">成果（売上・反響）が見えない</h3>
          <p class="text-zinc-400 font-jp leading-relaxed text-sm">
            アクセス数はあるのに問い合わせに繋がらない。どこに問題があるのか、感覚的な議論だけでデータに基づいた改善ができていない。
          </p>
        </div>

        <div class="glass-panel rounded-3xl p-8 glass-panel-hover group relative overflow-hidden mt-0 md:mt-16">
          <div class="absolute top-0 right-0 w-32 h-32 bg-[#ec4899]/10 rounded-full blur-3xl group-hover:bg-[#ec4899]/20 transition-all"></div>
          <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mb-6 text-[#ec4899] text-3xl group-hover:scale-110 transition-transform">
            <i class="ph ph-user-focus"></i>
          </div>
          <h3 class="text-xl font-jp font-bold mb-4 text-zinc-100">相談できる専門家がいない</h3>
          <p class="text-zinc-400 font-jp leading-relaxed text-sm">
            社内にWEBの知見を持つ人材がいない。制作会社に修正を依頼するのにも都度見積もりが必要で、スピード感のある施策が打てない。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SERVICE ========== -->
  <section class="py-32 px-6 relative">
    <div class="absolute left-0 top-1/2 -translate-y-1/2 w-1/3 h-full bg-gradient-to-r from-[#121212] to-transparent z-[-1]"></div>

    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-20">
      <div class="lg:w-1/3 relative">
        <div class="lg:sticky lg:top-32">
          <p class="text-[#9333ea] font-en font-bold tracking-widest text-sm mb-4">OUR SOLUTIONS</p>
          <h2 class="text-4xl lg:text-5xl font-jp font-bold leading-tight mb-6">
            AI × 人間の力で<br />
            WEBの課題を<br />
            すべて解決。
          </h2>
          <p class="text-zinc-400 font-jp leading-relaxed mb-8">
            最新のAIツールを活用した高速な分析・コンテンツ生成と、経験豊富なコンサルタントによる戦略設計。この両輪で、圧倒的なコストパフォーマンスと成果を実現します。
          </p>
          <div class="flex items-center gap-4">
            <span class="text-sm font-jp text-zinc-400">専属チームが伴走します</span>
          </div>
        </div>
      </div>

      <div class="lg:w-2/3 grid sm:grid-cols-2 gap-6 w-full">
        <div class="glass-panel p-8 rounded-3xl border-t border-[#2563eb]/30 relative overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-b from-[#2563eb]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative z-10">
            <div class="flex justify-between items-start mb-6">
              <div class="w-12 h-12 rounded-xl bg-[#2563eb]/10 flex items-center justify-center text-[#2563eb] border border-[#2563eb]/20">
                <i class="ph ph-magic-wand text-2xl"></i>
              </div>
              <span class="font-en text-zinc-600 font-bold text-lg">01</span>
            </div>
            <h3 class="text-xl font-jp font-bold mb-3 text-white">サイト改善・UI設計</h3>
            <p class="text-zinc-400 font-jp text-sm leading-relaxed">
              ヒートマップAIを用いてユーザーの離脱ポイントを特定。コンバージョン率を最大化するためのデザイン・導線改修をスピーディに実装します。
            </p>
          </div>
        </div>

        <div class="glass-panel p-8 rounded-3xl border-t border-[#4f46e5]/30 relative overflow-hidden group sm:translate-y-12">
          <div class="absolute inset-0 bg-gradient-to-b from-[#4f46e5]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative z-10">
            <div class="flex justify-between items-start mb-6">
              <div class="w-12 h-12 rounded-xl bg-[#4f46e5]/10 flex items-center justify-center text-[#4f46e5] border border-[#4f46e5]/20">
                <i class="ph ph-magnifying-glass text-2xl"></i>
              </div>
              <span class="font-en text-zinc-600 font-bold text-lg">02</span>
            </div>
            <h3 class="text-xl font-jp font-bold mb-3 text-white">SEO解析＆モニタリング</h3>
            <p class="text-zinc-400 font-jp text-sm leading-relaxed">
              競合サイトの構造やキーワード戦略をAIでディープに解析。検索順位の変動を監視し、最適な内部対策を迅速に提案します。
            </p>
          </div>
        </div>

        <div class="glass-panel p-8 rounded-3xl border-t border-[#9333ea]/30 relative overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-b from-[#9333ea]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative z-10">
            <div class="flex justify-between items-start mb-6">
              <div class="w-12 h-12 rounded-xl bg-[#9333ea]/10 flex items-center justify-center text-[#9333ea] border border-[#9333ea]/20">
                <i class="ph ph-article text-2xl"></i>
              </div>
              <span class="font-en text-zinc-600 font-bold text-lg">03</span>
            </div>
            <h3 class="text-xl font-jp font-bold mb-3 text-white">コンテンツ生成戦略</h3>
            <p class="text-zinc-400 font-jp text-sm leading-relaxed">
              ターゲットインサイトに基づいたブログ記事や導入事例の構成案をAIで高速生成。人間がエモーショナルな調整を加え、高品質な記事を量産します。
            </p>
          </div>
        </div>

        <div class="glass-panel p-8 rounded-3xl border-t border-[#ec4899]/30 relative overflow-hidden group sm:translate-y-12">
          <div class="absolute inset-0 bg-gradient-to-b from-[#ec4899]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative z-10">
            <div class="flex justify-between items-start mb-6">
              <div class="w-12 h-12 rounded-xl bg-[#ec4899]/10 flex items-center justify-center text-[#ec4899] border border-[#ec4899]/20">
                <i class="ph ph-megaphone text-2xl"></i>
              </div>
              <span class="font-en text-zinc-600 font-bold text-lg">04</span>
            </div>
            <h3 class="text-xl font-jp font-bold mb-3 text-white">広告最適化＆A/Bテスト</h3>
            <p class="text-zinc-400 font-jp text-sm leading-relaxed">
              機械学習を用いたクリエイティブの自動生成とABテストを実施。無駄な広告費を削り落とし、CPA（顧客獲得単価）を劇的に改善します。
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SOCIAL PROOF ========== -->
  <section class="py-32 px-6 bg-[#050505] relative overflow-hidden border-y border-white/5">
    <div class="absolute inset-0 z-0">
      <div class="absolute bg-white/[0.02] w-full h-[1px] top-1/3 -rotate-[10deg] scale-150"></div>
      <div class="absolute bg-white/[0.02] w-full h-[1px] bottom-1/3 rotate-[15deg] scale-150"></div>
    </div>

    <div class="max-w-7xl mx-auto relative z-10">
      <div class="flex flex-col md:flex-row justify-between items-center md:items-end mb-16 gap-8">
        <div>
          <h2 class="text-3xl font-jp w-full font-bold mb-2 text-white">圧倒的な実績が<br class="md:hidden" />証明する効果。</h2>
          <p class="text-zinc-500 font-jp text-sm">データは嘘をつきません。</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8 divide-y md:divide-y-0 md:divide-x divide-white/10">
        <div class="pt-8 md:pt-0 md:px-8 first:pt-0 first:md:pl-0 flex flex-col justify-end group">
          <div class="text-zinc-500 font-jp text-sm mb-4 group-hover:text-zinc-300 transition-colors">累計運用担当サイト数</div>
          <div class="flex items-baseline gap-2">
            <span class="text-7xl lg:text-[7rem] font-en font-black tracking-tighter bg-clip-text text-transparent bg-gradient-to-br from-white to-zinc-600 leading-none">73</span>
            <span class="text-xl font-jp text-zinc-400 font-bold">サイト</span>
          </div>
        </div>

        <div class="pt-8 md:pt-0 md:px-8 flex flex-col justify-end group">
          <div class="text-zinc-500 font-jp text-sm mb-4 group-hover:text-zinc-300 transition-colors">現在継続支援中の企業数</div>
          <div class="flex items-baseline gap-2">
            <span class="text-7xl lg:text-[7rem] font-en font-black tracking-tighter bg-clip-text text-transparent bg-gradient-to-br from-[#2563eb] to-[#9333ea] leading-none text-glow">28</span>
            <span class="text-5xl lg:text-7xl font-en font-black text-[#9333ea]">+</span>
            <span class="text-xl font-jp text-zinc-400 font-bold ml-2">社</span>
          </div>
        </div>

        <div class="pt-8 md:pt-0 md:px-8 flex flex-col justify-end group">
          <div class="text-zinc-500 font-jp text-sm mb-4 group-hover:text-zinc-300 transition-colors">平均CVR（成約率）改善率</div>
          <div class="flex items-baseline gap-2">
            <span class="text-7xl lg:text-[7rem] font-en font-black tracking-tighter bg-clip-text text-transparent bg-gradient-to-br from-[#9333ea] to-[#ec4899] leading-none text-glow">150</span>
            <span class="text-5xl lg:text-7xl font-en font-black text-[#ec4899]">%</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="py-32 px-6 relative">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-block px-4 py-1.5 rounded-full border border-[#9333ea]/30 bg-[#9333ea]/10 text-[#9333ea] text-xs font-en font-bold tracking-wider mb-6">
        SIMPLE PRICING
      </div>
      <h2 class="text-4xl md:text-5xl font-jp font-bold mb-6 text-white">専任WEB担当者を雇う<br />1/10のコストで。</h2>
      <p class="text-zinc-400 font-jp mb-16 max-w-2xl mx-auto leading-relaxed">
        採用コストも、教育コストも、退職リスクもゼロ。即戦力のエンジニアとコンサルタントチームが、月額2万円からあなたのビジネスをドライブさせます。
      </p>

      <div class="relative group mx-auto w-full max-w-3xl text-left">
        <div class="absolute -inset-1 bg-gradient-to-r from-[#2563eb] via-[#9333ea] to-[#ec4899] rounded-[2.5rem] blur-lg opacity-30 group-hover:opacity-60 transition duration-1000"></div>

        <div class="relative bg-[#0d0d0d] border border-white/10 rounded-[2.5rem] p-8 md:p-12 glass-panel flex flex-col md:flex-row gap-12 md:gap-8 items-center justify-between overflow-hidden">
          <div class="absolute top-0 right-0 w-1/2 h-full bg-[radial-gradient(ellipse_at_top_right,rgba(255,255,255,0.05),transparent)] pointer-events-none"></div>

          <div class="flex-1 w-full">
            <h3 class="text-2xl font-jp font-bold text-white mb-2">スタンダードコンサルティングプラン</h3>
            <p class="text-zinc-500 font-jp text-sm mb-8 pb-8 border-b border-white/10">サイト保守・運用 / SEO分析報告 / 月1回の定例MTG / チャット相談無制限</p>

            <ul class="space-y-4 font-jp text-zinc-300 text-sm">
              <li class="flex items-center gap-3">
                <i class="ph-fill ph-check-circle text-[#9333ea] text-lg"></i>
                初期設計・サイトAI診断
              </li>
              <li class="flex items-center gap-3">
                <i class="ph-fill ph-check-circle text-[#9333ea] text-lg"></i>
                月間レポート＆改善提案プロンプト提供

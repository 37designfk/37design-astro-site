---
import { getCollection } from 'astro:content';
import LPLayout from '../../layouts/LPLayout.astro';

export async function getStaticPaths() {
  const lpEntries = await getCollection('lp');
  return lpEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---
<LPLayout title={entry.data.title} description={entry.data.description} noIndex={entry.data.noIndex}>
  <Content />
</LPLayout>

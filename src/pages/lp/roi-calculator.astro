    document.getElementById('freed-hours').textContent = totalSavedPerPerson;
    var examplesHTML = '';
    var sorted = freedTimeExamples.slice().sort(function(a, b) { return Math.abs(a.hours - totalSavedPerPerson) - Math.abs(b.hours - totalSavedPerPerson); });
    sorted.slice(0, 3).forEach(function(ex) {
      examplesHTML += '<div class="flex items-start gap-2 bg-white rounded-xl p-3 border border-amber-100"><svg class="w-5 h-5 text-amber-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="' + ex.icon + '" /></svg><span class="text-sm text-text-primary font-medium">' + ex.text + '</span></div>';
    });
    document.getElementById('freed-time-examples').innerHTML = examplesHTML;

    document.getElementById('roi-value').textContent = monthlyCost.toLocaleString() + '円';
    var multiple = Math.round(monthlyCost / 20000 * 10) / 10;
    document.getElementById('roi-multiple').textContent = '投資対効果 ' + multiple + '倍';

    document.getElementById('result-section').scrollIntoView({ behavior: 'smooth', block: 'start' });

    window._roiData = {
      industry: selectedIndustry, employees: selectedEmployees,
      tasks: taskResults, totalSavedHours: totalSavedAll,
      totalSavedCost: monthlyCost, annualSavedCost: yearlyCost,
    };
  });

  function animateNumber(id, target, isCurrency) {
    var el = document.getElementById(id);
    var current = 0;
    var step = Math.max(1, Math.floor(target / 30));
    var interval = setInterval(function() {
      current += step;
      if (current >= target) { current = target; clearInterval(interval); }
      el.textContent = isCurrency ? current.toLocaleString() : current;
    }, 30);
  }

  document.getElementById('email-form').addEventListener('submit', function(e) {
    e.preventDefault();
    var email = document.getElementById('email-input').value;
    if (!email) return;
    var btn = this.querySelector('button');
    btn.textContent = '送信中...'; btn.disabled = true;

    try {
      var rd = window._roiData || {};
      fetch('https://n8n-37design.37d.jp/webhook/roi-calculator', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: email, industry: rd.industry, employees: rd.employees,
          tasks: rd.tasks, totalSavedHours: rd.totalSavedHours,
          totalSavedCost: rd.totalSavedCost, annualSavedCost: rd.annualSavedCost, source: 'lp',
        }),
      }).catch(function() {});
    } catch(err) { console.error('Webhook error:', err); }

    setTimeout(function() {
      document.getElementById('email-gate').classList.add('hidden');
      document.getElementById('post-email-cta').classList.remove('hidden');
    }, 800);
  });
})();
</script>

<script is:inline>
(function() {
  var sticky = document.getElementById('sticky-cta');
  if (sticky) {
    window.addEventListener('scroll', function() {
      if (window.scrollY > 300) {
        sticky.classList.remove('translate-y-full');
      } else {
        sticky.classList.add('translate-y-full');
      }
    }, { passive: true });
  }
})();
</script>


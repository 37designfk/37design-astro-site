    document.getElementById('result-section').classList.remove('hidden');
    animateNumber('saved-hours', totalSavedAll);
    animateNumber('saved-per-person', totalSavedPerPerson);
    animateNumber('saved-cost', monthlyCost, true);
    animateNumber('saved-yearly', yearlyCost, true);

---
import LPLayout from '../../layouts/LPLayout.astro';
import LPFooter from '../../components/lp/LPFooter.astro';
import ParticleCanvas from '../../components/ParticleCanvas.astro';
---

<LPLayout
  title="【無料】AI導入コスト削減シミュレーター｜御社の効率化ポテンシャルを即算出"
  description="業種と従業員数を入力するだけで、AI導入による月間・年間のコスト削減額を無料でシミュレーション。業務別の削減内訳と投資対効果もわかります。"
  image="https://37design.co.jp/images/ogp-roi-calculator.png"
  dashboardSlug="37design-roi-calculator"
>
  <!-- Hero -->
  <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 hero-gradient"></div>
    <ParticleCanvas />
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-16 md:py-24">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 border border-white/10 backdrop-blur-sm mb-6">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        <span class="text-white/70 text-xs font-medium">無料・登録不要・約1分で結果表示</span>
      </div>

      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-[3.5rem] font-black text-white leading-[1.2] mb-6">
        AI導入したら、<br />
        <span class="text-accent-400">いくら削減</span>できる？
      </h1>

      <p class="text-base sm:text-lg text-primary-200 max-w-2xl mx-auto leading-relaxed mb-4">
        業種と従業員数を入力するだけで、<br class="hidden md:block" />
        AI導入による<span class="text-white font-bold">月間削減時間・年間コスト削減額</span>を即算出。
      </p>

      <div class="inline-flex items-center gap-3 bg-white/10 backdrop-blur-sm rounded-xl px-6 py-3 mb-8">
        <span class="text-accent-400 text-2xl font-black">平均 年間120万円</span>
        <span class="text-white/60 text-sm">の削減効果*</span>
      </div>

      <div class="block">
        <a href="#start-simulator" class="inline-flex items-center gap-2 lp-cta-button px-10 py-5 rounded-full font-black text-lg hover:scale-[1.03] transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25V13.5Zm0 2.25h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25V18Zm2.498-6.75h.007v.008h-.007v-.008Zm0 2.25h.007v.008h-.007V13.5Zm0 2.25h.007v.008h-.007v-.008Zm0 2.25h.007v.008h-.007V18Zm2.504-6.75h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V13.5Zm0 2.25h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V18Zm2.498-6.75h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V13.5ZM8.25 6h7.5v2.25h-7.5V6ZM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 0 0 2.25 2.25h10.5a2.25 2.25 0 0 0 2.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0 0 12 2.25Z" />
          </svg>
          無料でシミュレーションする
        </a>
      </div>

      <p class="text-white/30 text-[10px] mt-4">*従業員10名・サービス業の平均シミュレーション結果</p>
    </div>
  </section>

  <!-- 課題共感 -->
  <section class="py-14 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl md:text-2xl font-bold text-text-primary text-center mb-10">
        こんなムダ、放置していませんか？
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          "毎日のメール対応に1時間以上かかっている",
          "議事録や報告書の作成で残業が発生している",
          "見積書・請求書を手作業で作っている",
          "同じような問い合わせに何度も対応している",
          "データ集計のためにExcelと格闘している",
          "SNS投稿やブログ記事を書く時間がない",
        ].map((text) => (
          <div class="flex items-start gap-3 bg-red-50/60 rounded-xl p-4 border border-red-100">
            <svg class="w-5 h-5 text-red-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            <span class="text-sm text-text-primary font-medium">{text}</span>
          </div>
        ))}
      </div>
      <p class="text-center text-text-secondary text-sm mt-8">
        これらの業務、AIで<span class="font-bold text-orange-600">30〜60%削減</span>できる可能性があります。
      </p>
    </div>
  </section>

  <!-- 使い方3ステップ -->
  <section class="py-14 md:py-20 bg-surface-alt">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl md:text-2xl font-bold text-text-primary text-center mb-10">
        <span class="text-orange-600">3ステップ</span>で削減額がわかる
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { step: "1", title: "業種と人数を選択", desc: "業種を選ぶと、よくある業務が自動で表示されます。", icon: "M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" },
          { step: "2", title: "業務時間を調整", desc: "スライダーで各業務の月間時間をざっくり入力。", icon: "M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75" },
          { step: "3", title: "結果を確認", desc: "削減時間・コスト・投資対効果が即座に表示。", icon: "M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" },
        ].map((item) => (
          <div class="bg-white rounded-2xl p-6 border border-gray-200 text-center">
            <div class="w-12 h-12 rounded-full bg-orange-500 text-white text-xl font-black flex items-center justify-center mx-auto mb-4">{item.step}</div>
            <svg class="w-8 h-8 text-orange-500 mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
            </svg>
            <h3 class="text-lg font-bold text-text-primary mb-2">{item.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 業種別削減事例 -->
  <section class="py-14 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl md:text-2xl font-bold text-text-primary text-center mb-10">
        業種別の<span class="text-orange-600">削減実績</span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { industry: "製造業（12名）", saved: "月32時間", cost: "年間96万円", task: "報告書・見積書のAI自動生成" },
          { industry: "士業（5名）", saved: "月45時間", cost: "年間135万円", task: "法令リサーチ・書類作成の自動化" },
          { industry: "小売・EC（8名）", saved: "月28時間", cost: "年間84万円", task: "商品説明文・SNS投稿のAI生成" },
          { industry: "サービス業（15名）", saved: "月50時間", cost: "年間150万円", task: "問い合わせ対応・議事録の効率化" },
          { industry: "不動産業（6名）", saved: "月22時間", cost: "年間66万円", task: "物件資料・追客メールの自動化" },
          { industry: "建設業（10名）", saved: "月35時間", cost: "年間105万円", task: "安全書類・日報作成の効率化" },
        ].map((item) => (
          <div class="bg-gradient-to-br from-orange-50 to-amber-50 rounded-xl p-5 border border-orange-100">
            <p class="text-xs text-text-secondary font-bold mb-2">{item.industry}</p>
            <p class="text-xl font-black text-orange-600 mb-1">{item.cost}<span class="text-xs font-normal text-text-secondary ml-1">削減</span></p>
            <p class="text-sm text-text-secondary">{item.saved}の短縮</p>
            <p class="text-xs text-text-muted mt-2 border-t border-orange-200/50 pt-2">{item.task}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- シミュレーター本体 -->
  <section id="start-simulator" class="py-16 md:py-24 bg-white scroll-mt-4">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Step 1 -->
      <div id="step1-section" class="rounded-2xl border border-gray-200 p-8 md:p-10">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-8 h-8 rounded-full bg-orange-500 text-white text-sm font-bold flex items-center justify-center">1</span>
          <h2 class="text-xl font-bold text-text-primary">業種と従業員数を選択</h2>
        </div>
        <div class="space-y-6">
          <div>
            <label for="industry" class="block text-sm font-bold text-text-primary mb-2">業種</label>
            <select id="industry" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none text-sm bg-white">
              <option value="">選択してください</option>
              <option value="manufacturing">製造業</option>
              <option value="retail">小売・EC</option>
              <option value="service">サービス業</option>
              <option value="realestate">不動産業</option>
              <option value="medical">医療・福祉</option>
              <option value="accounting">士業（税理士・社労士等）</option>
              <option value="it">IT・Web</option>
              <option value="construction">建設・建築</option>
              <option value="education">教育・スクール</option>
              <option value="other">その他</option>
            </select>
          </div>
          <div>
            <label for="employees" class="block text-sm font-bold text-text-primary mb-2">従業員数</label>
            <select id="employees" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none text-sm bg-white">
              <option value="">選択してください</option>
              <option value="1">1人（個人事業主）</option>
              <option value="3">2〜3人</option>
              <option value="5">4〜5人</option>
              <option value="10">6〜10人</option>
              <option value="20">11〜20人</option>
              <option value="30">21〜30人</option>
              <option value="50">31〜50人</option>
              <option value="100">51〜100人</option>
            </select>
          </div>
          <button id="step1-btn" type="button" class="w-full lp-cta-button py-4 rounded-xl font-bold text-lg cursor-pointer hover:scale-[1.02] transition-all">
            次へ：業務時間を入力
          </button>
        </div>
      </div>

      <!-- Step 2 -->
      <div id="step2-section" class="hidden rounded-2xl border border-gray-200 p-8 md:p-10">
        <div class="flex items-center gap-3 mb-2">
          <span class="w-8 h-8 rounded-full bg-orange-500 text-white text-sm font-bold flex items-center justify-center">2</span>
          <h2 class="text-xl font-bold text-text-primary">1人あたりの月間業務時間を入力</h2>
        </div>
        <p class="text-sm text-text-secondary mb-4">各業務に1人が月にどれくらい時間を使っているか、ざっくりでOKです。</p>
        <button id="back-to-step1" type="button" class="inline-flex items-center gap-1 text-sm text-text-secondary hover:text-orange-600 transition-colors mb-4 cursor-pointer">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          業種・従業員数を変更
        </button>
        <div class="space-y-5" id="task-inputs"></div>
        <div class="mt-6 pt-6 border-t border-gray-200">
          <div class="flex items-center justify-between mb-4">
            <span class="text-sm font-bold text-text-primary">合計</span>
            <span class="text-lg font-black text-text-primary" id="total-input-hours">0時間/月・人</span>
          </div>
          <button id="calc-btn" type="button" class="w-full lp-cta-button py-4 rounded-xl font-bold text-lg cursor-pointer hover:scale-[1.02] transition-all">
            AIで代替できる時間を診断する
          </button>
        </div>
      </div>

      <!-- 結果セクション -->
      <div id="result-section" class="hidden mt-10">
        <button id="back-to-step2" type="button" class="inline-flex items-center gap-1 text-sm text-text-secondary hover:text-orange-600 transition-colors mb-6 cursor-pointer">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          業務時間を修正する
        </button>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
          <div class="rounded-2xl bg-gradient-to-br from-orange-50 to-amber-50 border border-orange-200 p-5 text-center">
            <p class="text-xs text-text-secondary mb-1">全社 月間削減</p>
            <p class="text-3xl font-black text-orange-600" id="saved-hours">0</p>
            <p class="text-xs text-text-secondary mt-1">時間/月</p>
          </div>
          <div class="rounded-2xl bg-gradient-to-br from-purple-50 to-fuchsia-50 border border-purple-200 p-5 text-center">
            <p class="text-xs text-text-secondary mb-1">1人あたり削減</p>
            <p class="text-3xl font-black text-purple-600" id="saved-per-person">0</p>
            <p class="text-xs text-text-secondary mt-1">時間/月</p>
          </div>
          <div class="rounded-2xl bg-gradient-to-br from-green-50 to-emerald-50 border border-green-200 p-5 text-center">
            <p class="text-xs text-text-secondary mb-1">月間コスト削減</p>
            <p class="text-3xl font-black text-green-600" id="saved-cost">0</p>
            <p class="text-xs text-text-secondary mt-1">円/月</p>
          </div>
          <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-indigo-50 border border-blue-200 p-5 text-center">
            <p class="text-xs text-text-secondary mb-1">年間コスト削減</p>
            <p class="text-3xl font-black text-blue-600" id="saved-yearly">0</p>
            <p class="text-xs text-text-secondary mt-1">円/年</p>
          </div>
        </div>

        <div class="rounded-2xl bg-amber-50 border border-amber-200 p-6 mb-10">
          <h3 class="text-sm font-bold text-amber-800 mb-3">1人あたり毎月 <span id="freed-hours" class="text-lg">0</span>時間の余裕が生まれると...</h3>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3" id="freed-time-examples"></div>
        </div>

        <div class="rounded-2xl border border-gray-200 p-8 mb-10">
          <h3 class="text-lg font-bold text-text-primary mb-6">業務別 削減時間の内訳</h3>
          <div id="breakdown" class="space-y-4"></div>
        </div>

        <div class="rounded-2xl bg-primary-950 p-8 mb-10 text-center">
          <h3 class="text-lg font-bold text-white mb-2">AI顧問サービスとの比較</h3>
          <p class="text-primary-200 text-sm mb-6">月額2万円の投資で、これだけの効果が見込めます</p>
          <div class="inline-flex items-center gap-4">
            <div class="text-center">
              <p class="text-xs text-primary-300">月額投資</p>
              <p class="text-2xl font-bold text-white">20,000円</p>
            </div>
            <svg class="w-6 h-6 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            <div class="text-center">
              <p class="text-xs text-primary-300">月間削減効果</p>
              <p class="text-2xl font-bold text-accent-400" id="roi-value">0円</p>
            </div>
          </div>
          <p class="text-accent-400 font-bold text-lg mt-4" id="roi-multiple"></p>
        </div>

        <!-- メールゲート -->
        <div id="email-gate" class="rounded-2xl border-2 border-orange-500 bg-orange-50 p-8 text-center">
          <h3 class="text-xl font-bold text-text-primary mb-2">詳しいレポートをメールでお届け</h3>
          <p class="text-sm text-text-secondary mb-6">業種別のAI導入事例と、具体的なツール提案を含むレポートをお送りします。</p>
          <form id="email-form" class="max-w-md mx-auto flex flex-col sm:flex-row gap-3">
            <input type="email" id="email-input" placeholder="メールアドレス" required class="flex-1 px-4 py-3 rounded-xl border border-gray-300 bg-white focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none text-sm" />
            <button type="submit" class="lp-cta-button px-6 py-3 rounded-xl font-bold text-sm whitespace-nowrap">無料で受け取る</button>
          </form>
          <p class="text-xs text-text-secondary mt-3">※ メール配信はいつでも解除できます。</p>
        </div>

        <!-- メール後CTA + 特典 -->
        <div id="post-email-cta" class="hidden mt-10 rounded-2xl bg-primary-950 p-8 md:p-10">
          <div class="text-center mb-4">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-red-500/20 border border-red-400/30 mb-4">
              <span class="w-2 h-2 rounded-full bg-red-400 animate-pulse"></span>
              <span class="text-red-300 text-xs font-bold">今月の無料面談枠 残り3名</span>
            </div>
            <h3 class="text-2xl font-bold text-white mb-3">この削減効果を実現しませんか？</h3>
            <p class="text-primary-200 text-sm md:text-base">シミュレーション結果をもとに、具体的な導入プランを無料面談でご提案します。</p>
          </div>

          <!-- 特典 -->
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-5 mb-6">
            <p class="text-accent-400 text-xs font-bold tracking-wider uppercase mb-3 text-center">面談ご予約で3つの特典をプレゼント</p>
            <div class="space-y-2.5">
              <div class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-accent-400 text-primary-950 text-xs font-black flex items-center justify-center shrink-0 mt-0.5">1</span>
                <div>
                  <p class="text-white text-sm font-bold">御社専用 AI導入ロードマップ</p>
                  <p class="text-primary-300 text-xs">シミュレーション結果をもとに、3ヶ月・6ヶ月・1年の導入計画を作成</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-accent-400 text-primary-950 text-xs font-black flex items-center justify-center shrink-0 mt-0.5">2</span>
                <div>
                  <p class="text-white text-sm font-bold">すぐ使える ChatGPT プロンプト集 50選</p>
                  <p class="text-primary-300 text-xs">業種別にカスタマイズされた実践プロンプトPDF</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-accent-400 text-primary-950 text-xs font-black flex items-center justify-center shrink-0 mt-0.5">3</span>
                <div>
                  <p class="text-white text-sm font-bold">AI補助金・助成金 活用ガイド 2026年版</p>
                  <p class="text-primary-300 text-xs">最大450万円の補助金を活用するための申請ポイント解説</p>
                </div>
              </div>
            </div>
          </div>

          <div class="flex flex-col items-center gap-4">

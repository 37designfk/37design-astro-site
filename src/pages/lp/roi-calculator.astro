    var totalSavedPerPerson = 0;
    var breakdownHTML = '';
    var taskResults = [];

    data.tasks.forEach(function(task, i) {
      var inputHours = parseFloat(sliders[i].value);
      var saved = Math.round(inputHours * task.pct * 10) / 10;
      totalSavedPerPerson += saved;
      taskResults.push({ name: task.name, hours: inputHours, savedHours: saved, aiRate: task.pct });

      var totalSaved = Math.round(saved * selectedEmployees * 10) / 10;
      var barWidth = Math.min(100, Math.round(task.pct * 100));
      var savedPct = inputHours > 0 ? Math.round(saved / inputHours * 100) : 0;

      breakdownHTML += '<div><div class="flex justify-between items-center mb-1"><span class="text-sm font-medium text-text-primary">' + task.name + '</span><span class="text-sm font-bold text-orange-600">' + (selectedEmployees > 1 ? '<span class="text-xs text-text-secondary font-normal mr-1">1人 ' + saved + 'h →</span>全社 ' + totalSaved + 'h 削減' : saved + '時間 削減') + '</span></div><div class="w-full h-2 bg-gray-200 rounded-full overflow-hidden"><div class="h-full bg-gradient-to-r from-orange-500 to-amber-500 rounded-full" style="width:' + barWidth + '%"></div></div><p class="text-xs text-text-secondary mt-1">月 ' + inputHours + '時間 → <span class="font-bold text-green-600">' + (Math.round((inputHours - saved) * 10) / 10) + '時間に短縮</span>（' + savedPct + '%をAIが代替）</p></div>';
    });

    totalSavedPerPerson = Math.round(totalSavedPerPerson * 10) / 10;
    var totalSavedAll = Math.round(totalSavedPerPerson * selectedEmployees * 10) / 10;
    var monthlyCost = Math.round(totalSavedAll * hourlyRate);
    var yearlyCost = monthlyCost * 12;


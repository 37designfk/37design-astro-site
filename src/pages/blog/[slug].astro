---
import { getCollection } from 'astro:content';
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StructuredData from "../../components/common/StructuredData.astro";
import PersonSchema from "../../components/common/PersonSchema.astro";
import RelatedArticles from "../../components/blog/RelatedArticles.astro";
import AuthorBox from "../../components/blog/AuthorBox.astro";
import "../../styles/global.css";

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// 関連記事の解決: frontmatter優先 → 不足は同カテゴリ最新でフォールバック
const allPosts = await getCollection('blog', (p) => !p.data.noIndex);
const postBySlug = new Map(allPosts.map((p) => [p.slug, p]));

// 不正な relatedArticles slug をビルドで検出
const declaredRelated = post.data.relatedArticles ?? [];
const missingRelated = declaredRelated.filter((slug) => !postBySlug.has(slug));
if (missingRelated.length > 0) {
  throw new Error(
    `[blog/${post.slug}] relatedArticles に存在しない slug があります: ${missingRelated.join(', ')}`
  );
}

const explicitRelated = declaredRelated
  .map((slug) => postBySlug.get(slug))
  .filter((p): p is (typeof allPosts)[number] => Boolean(p));

const RELATED_COUNT = 3;
const needFallback = Math.max(0, RELATED_COUNT - explicitRelated.length);
const fallbackCandidates = needFallback > 0
  ? allPosts
      .filter(
        (p) =>
          p.slug !== post.slug &&
          p.data.category === post.data.category &&
          !explicitRelated.some((e) => e.slug === p.slug)
      )
      .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
      .slice(0, needFallback)
  : [];

const relatedArticles = [...explicitRelated, ...fallbackCandidates]
  .slice(0, RELATED_COUNT)
  .map((p) => ({
    slug: p.slug,
    title: p.data.title,
    description: p.data.description,
    publishDate: p.data.publishDate,
    category: p.data.category,
    image: p.data.image,
  }));

const ogImage = post.data.image
  ? post.data.image.startsWith('http')
    ? post.data.image
    : `https://37design.co.jp${post.data.image.startsWith('/') ? '' : '/'}${post.data.image}`
  : undefined;

// 本文から FAQ セクション（## ...FAQ... or よくある質問）を抽出して FAQPage 構造化データを生成
function extractFAQs(body: string): Array<{ question: string; answer: string }> {
  const lines = body.split('\n');
  const faqs: Array<{ question: string; answer: string }> = [];
  let inFaqSection = false;
  let current: { question: string; answer: string } | null = null;

  for (const rawLine of lines) {
    const line = rawLine.replace(/\r$/, '');
    const h2Match = line.match(/^##\s+(.+)/);
    if (h2Match) {
      if (current && current.answer.trim()) faqs.push(current);
      current = null;
      const heading = h2Match[1];
      inFaqSection = /FAQ|よくある質問|Q\s*&\s*A/i.test(heading);
      continue;
    }
    if (!inFaqSection) continue;
    const h3Match = line.match(/^###\s+(.+)/);
    if (h3Match) {
      if (current && current.answer.trim()) faqs.push(current);
      // Q1. / Q. / Q ：プレフィックスを除去
      const question = h3Match[1].replace(/^Q\d*[\.\:：]?\s*/i, '').trim();
      current = { question, answer: '' };
      continue;
    }
    if (current) {
      const trimmed = line.trim();
      if (!trimmed) continue;
      // A. プレフィックスを除去
      const cleaned = trimmed.replace(/^A\d*[\.\:：]?\s*/i, '');
      current.answer += (current.answer ? ' ' : '') + cleaned;
    }
  }
  if (current && current.answer.trim()) faqs.push(current);
  return faqs.filter((f) => f.question.length > 5 && f.answer.length > 20);
}

const faqs = extractFAQs(post.body);
const faqStructuredData = faqs.length >= 2
  ? {
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: {
          '@type': 'Answer',
          // Markdownリンク記法は除去してテキスト化
          text: f.answer.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/\*\*([^*]+)\*\*/g, '$1'),
        },
      })),
    }
  : null;

const categoryColors: Record<string, string> = {
  'AI': 'bg-amber-500/10 text-amber-600',
  '業務自動化': 'bg-purple-500/10 text-purple-600',
  'マーケティング': 'bg-blue-500/10 text-blue-600',
  'CRM': 'bg-green-500/10 text-green-600',
  'お知らせ': 'bg-gray-500/10 text-gray-600',
};
---

<Layout
  title={`${post.data.title} | 株式会社37Design`}
  description={post.data.description}
  image={ogImage}
  noindex={post.data.noIndex}
  ogType="article"
>
  <Header />

  <PersonSchema />

  {faqStructuredData && <StructuredData type="FAQPage" data={faqStructuredData} />}

  <StructuredData type="Article" data={{
    headline: post.data.title,
    description: post.data.description,
    image: ogImage,
    datePublished: post.data.publishDate.toISOString(),
    dateModified: (post.data.lastModified ?? post.data.publishDate).toISOString(),
    author: {
      '@type': 'Person',
      '@id': 'https://37design.co.jp/greeting/#person-furuta-ken',
      name: post.data.author,
      url: 'https://37design.co.jp/greeting/',
    },
    publisher: {
      '@type': 'Organization',
      '@id': 'https://37design.co.jp/#organization',
      name: '株式会社37Design',
      logo: {
        '@type': 'ImageObject',
        url: 'https://37design.co.jp/images/logo-gold.svg',
      },
    },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': new URL(Astro.url.pathname, 'https://37design.co.jp').href,
    },
    ...(post.data.targetKeyword ? { keywords: post.data.targetKeyword } : {}),
  }} />

  <StructuredData type="BreadcrumbList" data={{
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'ホーム',
        item: 'https://37design.co.jp/',
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'ブログ',
        item: 'https://37design.co.jp/blog/',
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: post.data.title,
      },
    ],
  }} />

  <main>
    <!-- Article Header -->
    <article class="py-16 md:py-20 bg-surface">
      <div class="max-w-4xl mx-auto px-4 md:px-6 lg:px-8">
        <!-- Breadcrumb -->
        <nav class="mb-8">
          <ol class="flex items-center gap-2 text-sm text-text-muted">
            <li><a href="/" class="hover:text-text-primary transition-colors">ホーム</a></li>
            <li>/</li>
            <li><a href="/blog/" class="hover:text-text-primary transition-colors">ブログ</a></li>
            <li>/</li>
            <li class="text-text-primary">{post.data.title}</li>
          </ol>
        </nav>

        <!-- Article Meta -->
        <div class="mb-8">
          <div class="flex items-center gap-3 mb-4 flex-wrap">
            <time datetime={post.data.publishDate.toISOString()} class="text-sm font-semibold text-text-muted">
              公開: {post.data.publishDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {post.data.lastModified && post.data.lastModified.getTime() !== post.data.publishDate.getTime() && (
              <time datetime={post.data.lastModified.toISOString()} class="text-sm font-semibold text-accent-600">
                更新: {post.data.lastModified.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            )}
            <span class={`inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold ${categoryColors[post.data.category]}`}>
              {post.data.category}
            </span>
          </div>
          <h1 class="text-3xl md:text-4xl font-black text-text-primary leading-tight mb-4">
            {post.data.title}
          </h1>
          <p class="text-lg text-text-secondary leading-relaxed">
            {post.data.description}
          </p>
          <div class="mt-6 pt-6 border-t border-border flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-accent-400/20 flex items-center justify-center text-accent-700 font-bold text-sm shrink-0">
              {post.data.author.charAt(0)}
            </div>
            <div>
              <p class="text-sm">
                <span class="text-text-muted">執筆者: </span>
                <a href="/greeting/" class="font-semibold text-text-primary hover:text-accent-600 transition-colors">{post.data.author}</a>
              </p>
              <p class="text-xs text-text-muted leading-snug mt-0.5">株式会社37Design 代表取締役 / 14プロダクト運用中の現役AI顧問</p>
            </div>
          </div>
        </div>

        <!-- Article Content -->
        <div class="bg-white rounded-2xl p-8 md:p-12 border border-border">
          <div class="prose prose-lg max-w-none
            prose-headings:font-bold prose-headings:text-text-primary
            prose-h1:text-3xl prose-h1:mb-6
            prose-h2:text-2xl prose-h2:mt-8 prose-h2:mb-4
            prose-h3:text-xl prose-h3:mt-6 prose-h3:mb-3
            prose-p:text-text-body prose-p:leading-relaxed prose-p:mb-6
            prose-a:text-accent-600 prose-a:no-underline hover:prose-a:underline
            prose-strong:text-text-primary prose-strong:font-bold
            prose-ul:list-disc prose-ul:pl-6 prose-ul:mb-6
            prose-ol:list-decimal prose-ol:pl-6 prose-ol:mb-6
            prose-li:text-text-body prose-li:mb-2
            prose-blockquote:border-l-4 prose-blockquote:border-accent-400 prose-blockquote:pl-4 prose-blockquote:italic prose-blockquote:text-text-secondary
            prose-code:bg-surface-alt prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:text-accent-600
            prose-pre:bg-primary-950 prose-pre:text-white prose-pre:p-4 prose-pre:rounded-lg prose-pre:overflow-x-auto
          ">
            <Content />
          </div>
        </div>

        <!-- 著者プロフィール: E-E-A-T強化 -->
        <AuthorBox
          name={post.data.author}
          role="株式会社37Design 代表取締役"
          bio="2012年に37Design設立、2019年からAI・マーケティング自動化の支援を本格展開。自社で14プロダクトを運用する現役AI顧問として、中小企業のDX推進を伴走支援。神戸を拠点に300以上のWebサイト運用実績あり。"
          image="/images/ceo-photo.jpg"
          socialLinks={[
            { label: '会社情報', href: '/greeting/', icon: '' },
            { label: 'X (Twitter)', href: 'https://x.com/37designfk', icon: '' },
          ]}
        />

        <!-- 関連記事: こんな記事も読まれています -->
        <RelatedArticles articles={relatedArticles} heading="こんな記事も読まれています" />

        <!-- Back to Blog -->
        <div class="mt-12 text-center">
          <a
            href="/blog/"
            class="inline-flex items-center gap-2 px-6 py-3 bg-surface-alt text-text-primary font-semibold rounded-full hover:bg-surface-dark transition-colors text-sm"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
            ブログ一覧に戻る
          </a>
        </div>
      </div>
    </article>

    <!-- CTA Section: AI顧問サービスへ集約 -->
    <section class="py-16 md:py-20 bg-primary-800 relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-0 left-1/4 w-96 h-96 bg-glow/5 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-accent-400/5 rounded-full blur-[100px]"></div>
      </div>

      <div class="relative max-w-4xl mx-auto px-4 md:px-6 lg:px-8 text-center">
        <p class="text-accent-400 text-xs md:text-sm font-semibold tracking-[.2em] uppercase mb-4">
          AI顧問サービス｜月額2万円〜
        </p>
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
          記事を読むだけで終わらせず、<br class="hidden md:inline" />御社の業務に実装しませんか？
        </h2>
        <p class="text-white/60 text-base md:text-lg mb-8 leading-relaxed">
          37Designの<strong class="text-white">AI顧問</strong>なら、ツール選定から構築・運用改善まで一気通貫で伴走。<br class="hidden md:inline" />
          14プロダクトを運用する現役AI顧問が、月額2万円から「動く仕組み」を作ります。
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/lp/ai-consulting/"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-accent-400 text-primary-950 font-bold rounded-full hover:bg-accent-300 transition-colors text-base"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" /></svg>
            AI顧問サービスを見る
          </a>
          <a
            href="/lp/ai-assessment/"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/10 text-white font-semibold rounded-full hover:bg-white/15 transition-colors text-base border border-white/20"
          >
            無料AI活用診断（約2分）
          </a>
        </div>

        <p class="text-white/40 text-xs mt-6">
          初期費用10万円・月額2万円〜 / 契約期間の縛りなし / 翌月解約OK
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

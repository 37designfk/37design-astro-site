---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import HeroCTABoxes from "../components/HeroCTABoxes.astro";
import Numbers from "../components/Numbers.astro";
import Services from "../components/Services.astro";
import Cases from "../components/Cases.astro";
import FAQ from "../components/FAQ.astro";
import About from "../components/About.astro";
import Testimonials from "../components/Testimonials.astro";
import CTA from "../components/CTA.astro";
import LatestPosts from "../components/LatestPosts.astro";
import Footer from "../components/Footer.astro";
import StickyCTA from "../components/StickyCTA.astro";
import "../styles/global.css";

const faqData = [
  {
    q: "Web AI顧問では、具体的に何を相談できますか？",
    a: "Webサイトの改善（SEO・アクセス解析・UI/UX）、AI導入（業務自動化・ツール選定・プロンプト設計）、マーケティング戦略（SNS運用・広告・コンテンツ）など、Web・AI・デジタルに関することなら何でもご相談いただけます。",
  },
  {
    q: "ITに詳しくなくても大丈夫ですか？",
    a: "はい、まったく問題ありません。専門用語を使わず分かりやすくご説明します。「AIって何ができるの？」というレベルからでもお気軽にご相談ください。",
  },
  {
    q: "費用はどのくらいかかりますか？",
    a: "初期費用10万円（税別）＋月額2万円（税別）です。外部コンサルティングの1/10以下のコストで、Web・AI分野の専門家に継続的に相談できます。いつでも解約可能です。",
  },
  {
    q: "契約期間の縛りはありますか？",
    a: "ありません。いつでも解約可能です。まずは1ヶ月お試しいただき、効果を実感してから継続をご判断ください。",
  },
  {
    q: "面談はどのように行いますか？",
    a: "Google Meetによるオンライン面談です。画面共有しながらサイトの改善点を確認したり、AI活用のデモをお見せすることもできます。面談以外にもチャットで随時ご相談いただけます。",
  },
  {
    q: "まだ具体的なイメージがないのですが相談できますか？",
    a: "もちろんです。「何から始めればいいか分からない」というご相談が最も多いです。無料面談で現状をお伺いし、優先順位をつけた施策をご提案します。無料面談だけでも構いません。",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqData.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a,
    },
  })),
};
---

<Layout>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header />
  <main>
    <Hero />
    <HeroCTABoxes />
    <Numbers />
    <Services />
    <Cases />
    <Testimonials />
    <FAQ />
    <About />
    <CTA />
    <LatestPosts />
  </main>
  <Footer />
  <StickyCTA />
</Layout>

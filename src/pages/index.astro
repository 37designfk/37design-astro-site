---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Numbers from "../components/Numbers.astro";
import Services from "../components/Services.astro";
import FAQ from "../components/FAQ.astro";
import About from "../components/About.astro";
import Testimonials from "../components/Testimonials.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const faqData = [
  {
    q: "Web AI顧問では、具体的に何を相談できますか？",
    a: "Webサイトの改善（SEO・アクセス解析・UI/UX）、AI導入（業務自動化・ツール選定・プロンプト設計）、マーケティング戦略（SNS運用・広告・コンテンツ）など、Web・AI・デジタルに関することなら何でもご相談いただけます。",
  },
  {
    q: "ITに詳しくなくても大丈夫ですか？",
    a: "はい、まったく問題ありません。専門用語を使わず分かりやすくご説明します。「AIって何ができるの？」というレベルからでもお気軽にご相談ください。",
  },
  {
    q: "費用はどのくらいかかりますか？",
    a: "初期費用10万円（税別）＋月額2万円〜（税別）です。面談回数に応じて月2回4万円・月4回8万円のプランもございます。初期費用には現状分析・課題整理・改善ロードマップ作成・初期環境構築が含まれます。外部コンサルティングの1/10以下のコストで、Web・AI分野の専門家に継続的に相談できます。",
  },
  {
    q: "契約期間の縛りはありますか？",
    a: "ありません。解約はいつでも可能で、当月末で終了できます。初期費用の返金はありませんが、月額費用は解約月以降は発生しません。まずは1ヶ月お試しいただき、効果を実感してから継続をご判断ください。",
  },
  {
    q: "面談はどのように行いますか？",
    a: "Google Meetによるオンライン面談を月1回（各回30〜60分）実施します。画面共有しながらサイトの改善点を確認したり、AI活用のデモをお見せすることもできます。面談以外にもチャット（LINE・メール）で随時ご相談いただけます。",
  },
  {
    q: "チャット相談の返信はどのくらいで届きますか？",
    a: "原則として営業日24時間以内に返信いたします。緊急のご相談はお電話でもお受けしています。「返信が来ない」という不安がないよう、受付確認の自動返信も設定しています。",
  },
  {
    q: "契約書や利用規約はありますか？",
    a: "はい、ご契約時にサービス利用契約書を締結します。サービス内容・料金・解約条件・秘密保持などを明記した契約書をお送りしますので、内容をご確認のうえサインいただきます。電子契約（クラウドサイン）にも対応しています。",
  },
  {
    q: "まだ具体的なイメージがないのですが相談できますか？",
    a: "もちろんです。「何から始めればいいか分からない」というご相談が最も多いです。無料面談で現状をお伺いし、優先順位をつけた施策をご提案します。無料面談だけでも構いません。",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqData.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a,
    },
  })),
};
---

<Layout>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header />
  <main>
    <Hero />
    <Numbers />
    <Services />
    <Testimonials />
    <FAQ />
    <About />
    <CTA />
  </main>
  <Footer />
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import "../../styles/global.css";
---

<Layout
  title="ChatGPT API・Anthropic API キー取得ガイド | 株式会社37Design"
  description="ChatGPT（OpenAI）APIキーとAnthropic（Claude）APIキーの取得手順を画像付きでわかりやすく解説。AI導入プロジェクトに必要なAPIキーの取得方法をステップバイステップでご案内します。"
>
  <Header />

  <main>
    <!-- Hero -->
    <section class="bg-primary-900 pt-28 pb-16">
      <div class="max-w-4xl mx-auto px-4 md:px-6 lg:px-8">
        <!-- Breadcrumb -->
        <nav class="text-sm mb-8" aria-label="パンくずリスト">
          <ol class="flex items-center gap-2 text-white/40">
            <li><a href="/" class="hover:text-white/70 transition-colors">ホーム</a></li>
            <li>/</li>
            <li class="text-white/70">APIキー取得ガイド</li>
          </ol>
        </nav>

        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 border border-white/10 backdrop-blur-sm mb-6">
          <span class="text-white/70 text-xs font-medium">Setup Guide</span>
        </div>

        <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-white leading-tight mb-6">
          APIキー取得ガイド
        </h1>
        <p class="text-white/60 text-base md:text-lg leading-relaxed max-w-2xl">
          AI導入プロジェクトで必要になるAPIキーの取得手順をご案内します。<br />
          このページの手順に沿って進めていただければ、5〜10分で完了します。
        </p>
      </div>
    </section>

    <!-- 目次 -->
    <section class="py-10 bg-surface border-b border-border">
      <div class="max-w-4xl mx-auto px-4 md:px-6 lg:px-8">
        <div class="bg-white rounded-xl p-6 border border-border">
          <h2 class="text-lg font-bold text-text-primary mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0ZM3.75 12h.007v.008H3.75V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm-.375 5.25h.007v.008H3.75v-.008Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
            </svg>
            このページの内容
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <a href="#openai" class="flex items-center gap-3 p-3 rounded-lg bg-surface-alt hover:bg-accent-50 border border-transparent hover:border-accent-200 transition-all group">
              <span class="w-8 h-8 rounded-lg bg-[#10a37f]/10 flex items-center justify-center text-sm font-bold text-[#10a37f] shrink-0">1</span>
              <span class="text-sm font-medium text-text-primary group-hover:text-accent-600 transition-colors">OpenAI（ChatGPT）APIキー</span>
            </a>
            <a href="#anthropic" class="flex items-center gap-3 p-3 rounded-lg bg-surface-alt hover:bg-accent-50 border border-transparent hover:border-accent-200 transition-all group">
              <span class="w-8 h-8 rounded-lg bg-[#d97757]/10 flex items-center justify-center text-sm font-bold text-[#d97757] shrink-0">2</span>
              <span class="text-sm font-medium text-text-primary group-hover:text-accent-600 transition-colors">Anthropic（Claude）APIキー</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- 注意事項 -->
    <section class="pt-10 pb-4 bg-surface">
      <div class="max-w-4xl mx-auto px-4 md:px-6 lg:px-8">
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-5">
          <div class="flex gap-3">
            <svg class="w-6 h-6 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
            </svg>
            <div>
              <p class="font-bold text-amber-800 text-sm mb-1">APIキーの取り扱いについて</p>
              <ul class="text-sm text-amber-700 space-y-1">
                <li>APIキーは<strong>パスワードと同じ</strong>です。他人に共有しないでください。</li>
                <li>弊社へお伝えいただく際は、<strong>メールやチャットに直接貼り付けず</strong>、弊社からお送りする専用フォームをご利用ください。</li>
                <li>APIの利用には<strong>従量課金</strong>が発生します。事前にクレジットカードの登録と利用上限の設定をおすすめします。</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== OpenAI ===== -->
    <section id="openai" class="py-12 md:py-16 bg-surface">
      <div class="max-w-4xl mx-auto px-4 md:px-6 lg:px-8">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-14 h-14 rounded-xl bg-[#10a37f] flex items-center justify-center shrink-0">
            <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-text-primary">OpenAI（ChatGPT）APIキーの取得</h2>
            <p class="text-sm text-text-muted mt-1">GPT-4o / GPT-4 / DALL-E などのモデルが利用可能</p>
          </div>
        </div>

        <div class="space-y-6">
          <!-- Step 1 -->
          <div class="bg-white rounded-xl border border-border overflow-hidden">
            <div class="flex items-center gap-3 p-5 border-b border-border bg-surface-alt">
              <span class="w-8 h-8 rounded-full bg-[#10a37f] flex items-center justify-center text-white text-sm font-bold shrink-0">1</span>
              <h3 class="font-bold text-text-primary">OpenAI にアカウント登録</h3>
            </div>
            <div class="p-5 space-y-3">
              <p class="text-sm text-text-secondary leading-relaxed">
                以下のURLにアクセスし、アカウントを作成してください。<br />
                Googleアカウント・Microsoftアカウントでもログインできます。
              </p>
              <a href="https://platform.openai.com/signup" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2.5 bg-[#10a37f] text-white text-sm font-medium rounded-lg hover:bg-[#0d8c6d] transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
                OpenAI Platform を開く
              </a>
              <p class="text-xs text-text-muted">※ ChatGPTのアカウントとは別です。「Platform」のアカウントが必要です。</p>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="bg-white rounded-xl border border-border overflow-hidden">
            <div class="flex items-center gap-3 p-5 border-b border-border bg-surface-alt">
              <span class="w-8 h-8 rounded-full bg-[#10a37f] flex items-center justify-center text-white text-sm font-bold shrink-0">2</span>
              <h3 class="font-bold text-text-primary">支払い情報を登録</h3>
            </div>
            <div class="p-5 space-y-3">
              <p class="text-sm text-text-secondary leading-relaxed">
                APIの利用には従量課金が発生するため、クレジットカードの登録が必要です。
              </p>
              <ol class="text-sm text-text-secondary space-y-2 list-none">
                <li class="flex gap-2">
                  <span class="text-[#10a37f] font-bold shrink-0">2-1.</span>
                  <span>ログイン後、右上の歯車アイコンから <strong>Settings</strong> を開く</span>
                </li>
                <li class="flex gap-2">
                  <span class="text-[#10a37f] font-bold shrink-0">2-2.</span>
                  <span>左メニューの <strong>Billing</strong> をクリック</span>
                </li>
                <li class="flex gap-2">
                  <span class="text-[#10a37f] font-bold shrink-0">2-3.</span>
                  <span><strong>Add payment details</strong> からクレジットカード情報を入力</span>
                </li>
                <li class="flex gap-2">
                  <span class="text-[#10a37f] font-bold shrink-0">2-4.</span>
                  <span>初回は <strong>$5〜$10 程度のチャージ</strong> で十分です（後から追加可能）</span>
                </li>
              </ol>
              <div class="bg-blue-50 border border-blue-200 rounded-lg p-3">
                <p class="text-xs text-blue-700">
                  <strong>利用上限の設定を推奨：</strong>Billing → Usage limits から月額上限（Monthly budget）を設定できます。想定外の高額請求を防ぐため、$20〜$50 程度に設定しておくと安心です。
                </p>
              </div>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="bg-white rounded-xl border border-border overflow-hidden">
            <div class="flex items-center gap-3 p-5 border-b border-border bg-surface-alt">
              <span class="w-8 h-8 rounded-full bg-[#10a37f] flex items-center justify-center text-white text-sm font-bold shrink-0">3</span>
              <h3 class="font-bold text-text-primary">APIキーを発行</h3>
            </div>
            <div class="p-5 space-y-3">
              <ol class="text-sm text-text-secondary space-y-2 list-none">
                <li class="flex gap-2">
                  <span class="text-[#10a37f] font-bold shrink-0">3-1.</span>
                  <span>左メニューの <strong>API keys</strong> をクリック（または下のボタンからアクセス）</span>
                </li>
                <li class="flex gap-2">
                  <span class="text-[#10a37f] font-bold shrink-0">3-2.</span>
                  <span><strong>Create new secret key</strong> ボタンをクリック</span>
                </li>
                <li class="flex gap-2">
                  <span class="text-[#10a37f] font-bold shrink-0">3-3.</span>
                  <span>Name 欄に用途がわかる名前を入力（例：<code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs">37design-project</code>）</span>
                </li>
                <li class="flex gap-2">
                  <span class="text-[#10a37f] font-bold shrink-0">3-4.</span>
                  <span>Permissions は <strong>All</strong> を選択</span>
                </li>
                <li class="flex gap-2">
                  <span class="text-[#10a37f] font-bold shrink-0">3-5.</span>
                  <span><strong>Create secret key</strong> をクリック</span>
                </li>
              </ol>
              <a href="https://platform.openai.com/api-keys" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2.5 bg-[#10a37f] text-white text-sm font-medium rounded-lg hover:bg-[#0d8c6d] transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z" />
                </svg>
                API Keys ページを開く
              </a>

              <div class="bg-red-50 border border-red-200 rounded-lg p-3">
                <p class="text-xs text-red-700">
                  <strong>重要：</strong>APIキーは作成時に一度だけ表示されます。必ずその場でコピーして安全な場所に保存してください。閉じると二度と確認できません。
                </p>
              </div>

              <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
                <p class="text-xs text-text-muted mb-2">APIキーの形式（例）：</p>
                <code class="text-sm text-text-primary bg-white px-3 py-2 rounded border border-gray-200 block font-mono">sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx</code>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Anthropic ===== -->
    <section id="anthropic" class="py-12 md:py-16 bg-surface-alt">
      <div class="max-w-4xl mx-auto px-4 md:px-6 lg:px-8">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-14 h-14 rounded-xl bg-[#d97757] flex items-center justify-center shrink-0">
            <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.304 2.016h-4.08l6.696 19.968h4.08L17.304 2.016Zm-10.608 0L0 21.984h4.08l1.32-4.08h6.48l1.32 4.08h4.08L10.608 2.016H6.696Zm-.72 12.768L8.64 7.344l2.664 7.44H5.976Z" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-text-primary">Anthropic（Claude）APIキーの取得</h2>
            <p class="text-sm text-text-muted mt-1">Claude Sonnet / Claude Opus / Claude Haiku などのモデルが利用可能</p>
          </div>
        </div>

        <div class="space-y-6">
          <!-- Step 1 -->
          <div class="bg-white rounded-xl border border-border overflow-hidden">
            <div class="flex items-center gap-3 p-5 border-b border-border bg-surface-alt">
              <span class="w-8 h-8 rounded-full bg-[#d97757] flex items-center justify-center text-white text-sm font-bold shrink-0">1</span>
              <h3 class="font-bold text-text-primary">Anthropic Console にアカウント登録</h3>
            </div>
            <div class="p-5 space-y-3">
              <p class="text-sm text-text-secondary leading-relaxed">
                以下のURLにアクセスし、アカウントを作成してください。<br />
                Googleアカウントでのログインにも対応しています。
              </p>
              <a href="https://console.anthropic.com/" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2.5 bg-[#d97757] text-white text-sm font-medium rounded-lg hover:bg-[#c4684a] transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
                Anthropic Console を開く
              </a>
              <p class="text-xs text-text-muted">※ claude.ai のアカウントとは別です。「Console」のアカウントが必要です。</p>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="bg-white rounded-xl border border-border overflow-hidden">
            <div class="flex items-center gap-3 p-5 border-b border-border bg-surface-alt">
              <span class="w-8 h-8 rounded-full bg-[#d97757] flex items-center justify-center text-white text-sm font-bold shrink-0">2</span>
              <h3 class="font-bold text-text-primary">支払い情報を登録</h3>
            </div>
            <div class="p-5 space-y-3">
              <p class="text-sm text-text-secondary leading-relaxed">
                APIの利用には従量課金が発生するため、クレジットカードの登録が必要です。
              </p>
              <ol class="text-sm text-text-secondary space-y-2 list-none">
                <li class="flex gap-2">
                  <span class="text-[#d97757] font-bold shrink-0">2-1.</span>
                  <span>ログイン後、左メニューの <strong>Settings</strong> をクリック</span>
                </li>
                <li class="flex gap-2">
                  <span class="text-[#d97757] font-bold shrink-0">2-2.</span>
                  <span><strong>Billing</strong> タブを開く</span>
                </li>
                <li class="flex gap-2">
                  <span class="text-[#d97757] font-bold shrink-0">2-3.</span>
                  <span><strong>Add Payment Method</strong> からクレジットカード情報を入力</span>
                </li>
                <li class="flex gap-2">
                  <span class="text-[#d97757] font-bold shrink-0">2-4.</span>
                  <span>初回は <strong>$5 のクレジット購入</strong> で十分です（後から追加可能）</span>
                </li>
              </ol>
              <div class="bg-blue-50 border border-blue-200 rounded-lg p-3">
                <p class="text-xs text-blue-700">
                  <strong>利用上限の設定を推奨：</strong>Settings → Plans & Billing → Spend Limits から月額上限を設定できます。$20〜$50 程度に設定しておくと安心です。
                </p>
              </div>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="bg-white rounded-xl border border-border overflow-hidden">
            <div class="flex items-center gap-3 p-5 border-b border-border bg-surface-alt">
              <span class="w-8 h-8 rounded-full bg-[#d97757] flex items-center justify-center text-white text-sm font-bold shrink-0">3</span>
              <h3 class="font-bold text-text-primary">APIキーを発行</h3>
            </div>
            <div class="p-5 space-y-3">
              <ol class="text-sm text-text-secondary space-y-2 list-none">
                <li class="flex gap-2">
                  <span class="text-[#d97757] font-bold shrink-0">3-1.</span>
                  <span>左メニューの <strong>API Keys</strong> をクリック（または下のボタンからアクセス）</span>
                </li>
                <li class="flex gap-2">
                  <span class="text-[#d97757] font-bold shrink-0">3-2.</span>
                  <span><strong>Create Key</strong> ボタンをクリック</span>
                </li>
                <li class="flex gap-2">
                  <span class="text-[#d97757] font-bold shrink-0">3-3.</span>
                  <span>Name 欄に用途がわかる名前を入力（例：<code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs">37design-project</code>）</span>
                </li>
                <li class="flex gap-2">
                  <span class="text-[#d97757] font-bold shrink-0">3-4.</span>
                  <span><strong>Create Key</strong> をクリック</span>
                </li>
              </ol>
              <a href="https://console.anthropic.com/settings/keys" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2.5 bg-[#d97757] text-white text-sm font-medium rounded-lg hover:bg-[#c4684a] transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z" />
                </svg>
                API Keys ページを開く
              </a>

              <div class="bg-red-50 border border-red-200 rounded-lg p-3">
                <p class="text-xs text-red-700">
                  <strong>重要：</strong>APIキーは作成時に一度だけ表示されます。必ずその場でコピーして安全な場所に保存してください。閉じると二度と確認できません。
                </p>
              </div>

              <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
                <p class="text-xs text-text-muted mb-2">APIキーの形式（例）：</p>
                <code class="text-sm text-text-primary bg-white px-3 py-2 rounded border border-gray-200 block font-mono">sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx</code>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- APIキーの共有方法 -->

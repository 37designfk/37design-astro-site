---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const categories = [
  {
    id: "service",
    title: "サービス全般",
    items: [
      { q: "37DesignのAI顧問では、具体的に何を相談できますか?", a: "Webサイトの改善 (SEO・アクセス解析・UI/UX)、AI導入 (業務自動化・ツール選定・プロンプト設計)、マーケティング戦略 (SNS運用・広告・コンテンツ)、Claude / ChatGPT / Gemini 等の業務組み込みなど、Web・AI・デジタルに関することなら何でもご相談いただけます。詳細は[AI顧問サービスのご案内](/lp/ai-consulting/)をご参照ください。" },
      { q: "ITに詳しくなくても大丈夫ですか?", a: "完全に問題ありません。専門用語を使わず分かりやすくご説明します。「AIって何ができるの?」というレベルからでも丁寧に伴走します。" },
      { q: "対応可能エリアはどこですか?", a: "全国対応です。基本はGoogle Meetによるオンラインで進行しますが、神戸・東京エリアは対面打ち合わせも対応可能です。" },
      { q: "まだ具体的なイメージがないのですが相談できますか?", a: "もちろんです。「何から始めればいいか分からない」というご相談が最も多いです。無料面談で現状をお伺いし、優先順位をつけた施策をご提案します。無料面談だけでも構いません。" },
    ],
  },
  {
    id: "pricing",
    title: "料金・契約",
    items: [
      { q: "費用はどのくらいかかりますか?", a: "初期費用10万円 (税別) + 月額2万円〜 (税別) です。面談回数に応じて月2回4万円・月4回8万円のプランもございます。初期費用には現状分析・課題整理・改善ロードマップ作成・初期環境構築が含まれます。外部コンサルティングの1/10以下のコストで、Web・AI分野の専門家に継続的にご相談いただけます。" },
      { q: "契約期間の縛りはありますか?", a: "ありません。解約はいつでも可能で、当月末で終了できます。初期費用の返金はありませんが、月額費用は解約月以降は発生しません。まずは1ヶ月お試しいただき、効果を実感してから継続をご判断ください。" },
      { q: "契約書や利用規約はありますか?", a: "はい、ご契約時にサービス利用契約書を締結します。サービス内容・料金・解約条件・秘密保持などを明記した契約書をお送りしますので、内容をご確認のうえサインいただきます。電子契約 (クラウドサイン) にも対応しています。" },
      { q: "支払い方法は何がありますか?", a: "請求書による銀行振込、クレジットカード払い (Stripe経由) に対応しています。インボイス制度対応の適格請求書を発行可能です。" },
      { q: "IT導入補助金は使えますか?", a: "ケースバイケースで対応可能性があります。AI顧問サービスが補助金対象になる条件・申請の流れは、初回相談時にご案内します。詳細は[AI顧問の費用相場記事](/blog/ai-advisor-fee-comparison-2026/)もご参照ください。" },
    ],
  },
  {
    id: "consultation",
    title: "面談・コミュニケーション",
    items: [
      { q: "面談はどのように行いますか?", a: "Google Meetによるオンライン面談を月1回 (各回30〜60分) 実施します。画面共有しながらサイトの改善点を確認したり、AI活用のデモをお見せすることもできます。面談以外にもチャット (LINE・メール) で随時ご相談いただけます。" },
      { q: "チャット相談の返信はどのくらいで届きますか?", a: "原則として営業日24時間以内に返信いたします。緊急のご相談はお電話でもお受けしています。「返信が来ない」という不安がないよう、受付確認の自動返信も設定しています。" },
      { q: "面談の前に準備するものはありますか?", a: "現状で困っていることを箇条書きで3-5つご用意いただければ十分です。Webサイト・アクセス解析画面のURLや、業務フローの簡単なメモがあると進行がスムーズです。" },
      { q: "面談を録画して後から見返せますか?", a: "はい、ご希望に応じて録画を共有可能です。当社では自社プロダクト「Lexion Hub Meetings」で議事録自動生成もご提供できます。" },
    ],
  },
  {
    id: "ai-implementation",
    title: "AI導入・実装関連",
    items: [
      { q: "どのAIツール (Claude / ChatGPT / Gemini) がうちの会社に合いますか?", a: "業務内容によって最適解が変わります。長文処理・コード生成・社内ドキュメント整理はClaude、画像生成・最新情報検索はChatGPT、Google Workspace連携はGeminiが定石です。詳しくは[Claude完全ガイド](/blog/claude-ai-complete-guide-sme-2026/)も参照してください。" },
      { q: "AIの機密情報・個人情報の取り扱いは大丈夫ですか?", a: "重要なテーマです。Claude / ChatGPT の通常プランは会話データが学習に使われる可能性があるため、機密情報を扱う場合はAPI利用またはEnterpriseプランを選択する必要があります。AI顧問では業務特性に応じた最適構成をご提案します。" },
      { q: "自社専用のAIエージェント (Claude Code / OpenClaw / Hermes Agent) を構築できますか?", a: "はい、対応可能です。当社では Claude Code を週77時間運用 (月300時間到達が次の目標) しており、OpenClaw / Hermes Agent も自社で実運用しています。経営者向けの実装支援は[Claude Code完全ガイド](/blog/claude-code-complete-guide-for-business-owners-2026/) / [OpenClaw完全ガイド](/blog/openclaw-complete-guide-claude-code-oss-2026/) / [Hermes Agent完全ガイド](/blog/hermes-agent-complete-guide-for-business-2026/) でも解説しています。" },
      { q: "AI導入の効果はどのくらいで出ますか?", a: "業務によりますが、定型業務 (議事録整理・メール返信・レポート生成) は1-2週間で効果実感、本格的な業務自動化は1-3ヶ月、フル統合 (4段コンパウンド構築) は3-6ヶ月が目安です。詳細は[4段コンパウンド設計記事](/blog/ai-marketing-4layer-compound-sme-2026/)。" },
      { q: "AIに関する用語が分からないのですが・・・", a: "[AI用語集](/glossary/) ページで生成AI基礎・Claude・AIエージェント・AIマーケティング・経営者向けの50用語を一次情報ベースで整理しています。ご相談前のキャッチアップとしてご活用ください。" },
    ],
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": categories.flatMap((cat) =>
    cat.items.map((item) => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.a.replace(/\[([^\]]+)\]\([^)]+\)/g, "$1").replace(/\*\*([^*]+)\*\*/g, "$1"),
      },
    }))
  ),
};
---

<Layout
  title="よくあるご質問 (FAQ) | 株式会社37Design"
  description="37DesignのAI顧問サービスに関するよくあるご質問。料金・契約・面談・AI導入・実装まで、サービス全般のFAQを17問体系化。AI用語集と併用してご活用ください。"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <Header />

  <main>
    <section class="relative min-h-[40vh] flex items-center hero-gradient overflow-hidden">
      <div class="absolute inset-0 pointer-events-none z-[2]" aria-hidden="true">
        <div class="absolute top-[20%] right-[15%] w-72 h-72 bg-glow/8 rounded-full blur-[100px]"></div>
        <div class="absolute bottom-[10%] left-[10%] w-96 h-96 bg-accent-400/5 rounded-full blur-[120px]"></div>
      </div>
      <div class="relative z-20 max-w-5xl mx-auto px-4 md:px-6 lg:px-8 py-16 md:py-20 w-full text-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 border border-white/10 backdrop-blur-sm mb-6">
          <span class="text-white/70 text-xs font-medium">FAQ</span>
        </div>
        <h1 class="text-[clamp(2rem,5vw,3.5rem)] font-black text-white leading-[1.15] mb-4">
          よくあるご質問
        </h1>
        <p class="text-white/70 text-base md:text-lg leading-relaxed max-w-2xl mx-auto">
          37Design のAI顧問サービスに関する<br />
          よくいただくご質問をまとめました
        </p>
      </div>
    </section>

    <section class="py-12 md:py-16 bg-surface">
      <div class="max-w-4xl mx-auto px-4 md:px-6 lg:px-8">

        <nav class="mb-12 bg-white rounded-2xl p-6 md:p-8 border border-border">
          <p class="text-sm font-semibold text-text-muted uppercase tracking-wider mb-4">カテゴリ目次</p>
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-2 text-sm">
            {categories.map((cat) => (
              <li>
                <a href={`#${cat.id}`} class="text-accent-600 hover:underline font-semibold">{cat.title}</a>
                <span class="text-text-muted ml-2">({cat.items.length}問)</span>
              </li>
            ))}
          </ul>
        </nav>

        {categories.map((cat) => (
          <section id={cat.id} class="mb-12 scroll-mt-24">
            <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-6 pb-3 border-b-2 border-accent-400">
              {cat.title}
            </h2>
            <div class="space-y-4">
              {cat.items.map((item) => (
                <details class="bg-white rounded-xl p-5 md:p-6 border border-border group">
                  <summary class="text-base md:text-lg font-bold text-text-primary cursor-pointer leading-relaxed list-none flex items-start gap-3">
                    <span class="text-accent-600 font-black shrink-0 mt-0.5">Q.</span>
                    <span class="flex-1">{item.q}</span>
                    <span class="text-text-muted shrink-0 mt-0.5 group-open:rotate-180 transition-transform">+</span>
                  </summary>
                  <div class="mt-4 pt-4 border-t border-border text-sm md:text-base text-text-body leading-relaxed pl-7" set:html={item.a.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="text-accent-600 hover:underline">$1</a>').replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')} />
                </details>
              ))}
            </div>
          </section>
        ))}

      </div>
    </section>

    <section class="py-16 md:py-20 bg-primary-800 relative overflow-hidden">
      <div class="relative max-w-4xl mx-auto px-4 md:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
          ここに無い質問は、無料相談で直接お聞きください
        </h2>
        <p class="text-white/60 text-base md:text-lg mb-8">
          初回のご相談は完全無料、契約義務は一切ありません
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact/" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-accent-400 text-primary-950 font-bold rounded-full hover:bg-accent-300 transition-colors text-base">
            無料相談のお問い合わせ
          </a>
          <a href="/lp/ai-consulting/" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/10 text-white font-semibold rounded-full hover:bg-white/15 transition-colors text-base border border-white/20">
            AI顧問サービスを見る
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

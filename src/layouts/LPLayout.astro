---
import "../styles/global.css";
import "../styles/lp-base.css";

interface Props {
  title: string;
  description: string;
  image?: string;
  noIndex?: boolean;
}

const { title, description, image = "https://37design.co.jp/images/ogp.png", noIndex = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0f1e" />
    <meta http-equiv="Content-Security-Policy" content="upgrade-insecure-requests; block-all-mixed-content" />
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="株式会社37Design" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:creator" content="@37designfk" />
    <meta name="twitter:site" content="@37designfk" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="preconnect" href="https://plausible.37d.jp" crossorigin />
    <title>{title}</title>

    <!-- GA4 - deferred for performance -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-3NZGR1VGR8');
      (function(){var s=document.createElement('script');s.src='https://www.googletagmanager.com/gtag/js?id=G-3NZGR1VGR8';s.async=true;
      if('requestIdleCallback' in window){requestIdleCallback(function(){document.head.appendChild(s)},{timeout:3000})}
      else{setTimeout(function(){document.head.appendChild(s)},2000)}})();
    </script>

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": title,
      "description": description,
      "url": canonicalURL.href,
      "image": image,
      "publisher": {
        "@type": "Organization",
        "@id": "https://37design.co.jp/#organization",
        "name": "株式会社37Design",
        "url": "https://37design.co.jp",
        "logo": {
          "@type": "ImageObject",
          "url": "https://37design.co.jp/images/logo-gold.svg"
        }
      }
    })} />
    <!-- Clarity - deferred for performance -->
    <script type="text/javascript" is:inline>
      window.clarity=window.clarity||function(){(window.clarity.q=window.clarity.q||[]).push(arguments)};
      (function(){function loadClarity(){var t=document.createElement('script');t.async=1;t.src='https://www.clarity.ms/tag/voqlg18k81';document.head.appendChild(t)}
      if('requestIdleCallback' in window){requestIdleCallback(loadClarity,{timeout:4000})}
      else{setTimeout(loadClarity,3000)}})();
    </script>
  </head>
  <body class="bg-surface text-text-body font-sans antialiased overflow-x-hidden">
    <slot />

    <script>
      import { init } from "@plausible-analytics/tracker";

      init({
        domain: "37design.co.jp",
        endpoint: "https://plausible.37d.jp/api/event",
      });

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      document.querySelectorAll(".animate-on-scroll").forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>

---
import ParticleCanvas from "./ParticleCanvas.astro";
---

<section class="relative min-h-[calc(100vh-4rem)] flex items-center hero-gradient hero-gradient-home overflow-x-hidden">
  <!-- Generated cosmic FV background (DESIGN.md準拠) -->
  <img
    src="/hero-bg.jpg"
    alt=""
    aria-hidden="true"
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 h-full w-full object-cover opacity-85 z-0 pointer-events-none select-none"
  />
  <!-- Dark center overlay for text legibility -->
  <div class="absolute inset-0 z-[1] bg-[radial-gradient(ellipse_at_center,rgba(10,15,30,0.65)_0%,rgba(10,15,30,0.35)_45%,transparent_75%)] pointer-events-none"></div>

  <ParticleCanvas />

  <!-- Background accents -->
  <div class="absolute inset-0 pointer-events-none z-[2]" aria-hidden="true">
    <div class="absolute inset-0 hero-vignette"></div>
  </div>

  <div class="relative z-20 max-w-5xl mx-auto px-4 md:px-6 lg:px-8 py-24 md:py-32 w-full">

    <!-- Badge -->
    <div class="flex justify-center mb-8">
      <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-amber-500/12 border border-amber-400/20">
        <span class="w-2 h-2 rounded-full bg-amber-400"></span>
        <span class="text-white/80 text-xs font-semibold">中小企業向けAI顧問サービス｜初回無料面談 受付中</span>
      </div>
    </div>

    <!-- Main headline -->
    <div class="text-center">
      <h1 class="text-[clamp(2.2rem,6vw,5rem)] font-black text-white leading-[1.08] mb-6 tracking-tight">
        AIのことは、<br />
        <span class="relative inline-block">
          <span class="relative z-10 text-accent-400">AI顧問に聞こう。</span>
          <span class="absolute bottom-1 left-0 right-0 h-3 md:h-4 bg-accent-400/15 -skew-x-3 rounded-sm"></span>
        </span>
      </h1>

      <p class="text-white/50 text-base md:text-xl leading-relaxed max-w-2xl mx-auto mb-4">
        AI導入・業務自動化・サイト改善。月額2万円〜で<br class="hidden md:block" />
        14プロダクトを運用する現役AI顧問が、御社専属で伴走します。
      </p>

      <!-- Value line -->
      <div class="flex items-center justify-center gap-3 mb-8">
        <div class="h-px w-8 bg-accent-400/40"></div>
        <p class="text-accent-400/80 text-sm font-semibold">
          外部コンサルの<span class="text-accent-400 font-bold">1/10以下</span>のコスト・<span class="text-accent-400 font-bold">いつでも解約OK</span>
        </p>
        <div class="h-px w-8 bg-accent-400/40"></div>
      </div>

      <!-- Primary CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4 mb-5">
        <a
          href="https://cal.37d.jp/37design/ai%E7%9B%B8%E8%AB%87"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-amber-500 to-orange-600 hover:from-amber-400 hover:to-orange-500 text-white font-black rounded-full text-base shadow-[0_8px_30px_rgba(234,88,12,0.35)] hover:shadow-[0_12px_40px_rgba(234,88,12,0.5)] transition-all w-full sm:w-auto btn-pulse"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
          </svg>
          無料面談を予約する
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a
          href="/lp/ai-assessment/"
          class="inline-flex items-center justify-center gap-2 px-7 py-4 bg-white/10 hover:bg-white/15 text-white font-bold rounded-full text-base border border-white/20 backdrop-blur-sm transition-colors w-full sm:w-auto"
        >
          <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
          </svg>
          無料AI診断を試す
        </a>
      </div>

      <!-- LINE secondary -->
      <div class="flex justify-center mb-8">
        <a
          href="https://jmp9xv65.autosns.app/line"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2 rounded-full text-white/70 hover:text-white text-sm transition-colors"
        >
          <svg class="w-4 h-4 text-[#06C755]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314" />
          </svg>
          LINEで気軽に相談する
        </a>
      </div>
    </div>

    <!-- CTA qualifiers -->
    <div class="flex flex-col items-center gap-3">
      <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-1 text-white/40 text-xs">
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-green-400/70" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          初回30分・無料
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-green-400/70" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          オンライン完結
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-green-400/70" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          しつこい営業なし
        </span>
      </div>
    </div>

    <!-- Trust numbers -->
    <div class="mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-white/40 text-xs">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-accent-400/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
        </svg>
        <span><strong class="text-white/60">50社+</strong> 支援実績</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-accent-400/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
        </svg>
        <span><strong class="text-white/60">98%</strong> 顧客満足度</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-accent-400/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <span>月額<strong class="text-white/60">2万円</strong>から</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 text-white/50 text-[10px] tracking-[.2em] uppercase text-center scroll-indicator">
    Scroll
  </div>

</section>

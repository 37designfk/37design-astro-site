---
const features = [
  {
    icon: "M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418",
    title: "Webサイト改善",
    description: "SEO対策、アクセス解析、UI/UX改善。データに基づいた施策で集客力を強化します。",
  },
  {
    icon: "M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z",
    title: "AI導入支援",
    description: "業務に合ったAIツールの選定から導入、プロンプト設計、ワークフロー自動化まで。",
  },
  {
    icon: "M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z",
    title: "マーケティング戦略",
    description: "SNS運用、コンテンツ戦略、広告運用。デジタル施策全般を一緒に考え、実行します。",
  },
  {
    icon: "M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 0 1-.825-.242m9.345-8.334a2.126 2.126 0 0 0-.476-.095 48.64 48.64 0 0 0-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0 0 11.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155",
    title: "定期オンライン面談",
    description: "Google Meetで直接相談。課題の整理から施策の優先順位づけまで、伴走します。",
  },
];
import WaveDivider from "./WaveDivider.astro";
---

<section id="services" class="relative py-16 md:py-20 lg:py-24 bg-surface-alt">
  <div class="max-w-6xl mx-auto px-4 md:px-6 lg:px-8">
    <div class="text-center mb-12 md:mb-16 animate-on-scroll">
      <p class="text-primary-500 text-sm font-semibold tracking-[.2em] uppercase mb-3">Service</p>
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
        Web・AIの専門家が、<span class="marker-highlight">月額2万円</span>で伴走
      </h2>
      <p class="mt-4 text-sm md:text-base text-text-secondary max-w-2xl mx-auto leading-relaxed">
        「AIを導入したいけど、何から始めればいいか分からない」「Webサイトの改善を相談できる相手がいない」…そんな課題を、オンライン完結の顧問サービスで解決します。
      </p>
    </div>

    <!-- Main Service Card -->
    <div class="animate-on-scroll max-w-4xl mx-auto">
      <div class="block group relative rounded-2xl overflow-hidden bg-gradient-to-r from-amber-500 to-orange-600 p-[2px] hover:shadow-2xl transition-all duration-300">
        <div class="relative rounded-[14px] bg-white px-6 py-8 md:px-10 md:py-10">
          <div class="flex flex-col md:flex-row items-center gap-6 md:gap-10">
            <div class="w-16 h-16 md:w-20 md:h-20 rounded-2xl bg-gradient-to-br from-amber-500 to-orange-600 flex items-center justify-center shrink-0">
              <svg class="w-8 h-8 md:w-10 md:h-10 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5l4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />
              </svg>
            </div>

            <div class="flex-1 text-center md:text-left">
              <p class="text-xs font-semibold text-amber-600 tracking-wider uppercase mb-2">Web AI Advisory</p>
              <h3 class="text-2xl md:text-3xl font-bold text-text-primary mb-3">Web AI顧問</h3>
              <p class="text-sm md:text-base text-text-secondary leading-relaxed">
                外部コンサルの<strong class="text-text-primary">1/10以下のコスト</strong>で、Web戦略からAI活用まで何でも相談できる。初期費用10万円＋月額2万円で、御社専属のWeb・AI参謀がつきます。いつでも解約可能。
              </p>
            </div>

            <div class="text-center shrink-0">
              <p class="text-sm text-text-muted">月額</p>
              <p class="text-4xl md:text-5xl font-black bg-gradient-to-r from-amber-500 to-orange-600 bg-clip-text text-transparent">20,000<span class="text-lg">円〜</span></p>
              <p class="text-[11px] text-text-muted mt-1">初期費用 100,000円</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- What's included -->
    <div class="mt-12 md:mt-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-4xl mx-auto">
      {features.map((feature, i) => (
        <div
          class="animate-on-scroll text-center p-5 rounded-xl bg-white border border-border"
          style={`animation-delay: ${i * 0.1}s`}
        >
          <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
            </svg>
          </div>
          <h4 class="text-sm font-bold text-text-primary mb-1.5">{feature.title}</h4>
          <p class="text-xs text-text-secondary leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-10 text-center animate-on-scroll">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/lp/ai-assessment/" class="inline-flex items-center gap-2 bg-gradient-to-r from-amber-500 to-orange-600 text-white font-bold px-7 py-3.5 rounded-full hover:shadow-lg hover:scale-105 transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
          </svg>
          <span>AI活用度を診断する</span>
        </a>
        <a href="/lp/roi-calculator/" class="inline-flex items-center gap-2 border-2 border-amber-500 text-amber-600 font-bold px-7 py-3.5 rounded-full hover:bg-amber-50 transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <span>コスト削減額を試算する</span>
        </a>
      </div>
      <p class="text-xs text-text-muted mt-3">どちらも約2分・登録不要で完了します。</p>
    </div>
  </div>
  <WaveDivider color1="#0a0f1e" />
</section>

---
const services = [
  { name: "WEB IMPROVEMENT", title: "Webサイト改善", models: "SEO対策 / アクセス解析 / UI/UX改善 / データ分析" },
  { name: "AI INTEGRATION", title: "AI導入支援", models: "ChatGPT / Claude / Dify / n8n / 自動化設計" },
  { name: "MARKETING", title: "マーケティング戦略", models: "SNS運用 / コンテンツ / 広告運用 / CRM" },
  { name: "ADVISORY", title: "定期オンライン面談", models: "Google Meet / チャット相談 / 月次レポート" },
];

const deliverables = [
  { label: "月次レポート", desc: "アクセス解析・改善結果をまとめた報告書" },
  { label: "チャット相談 無制限", desc: "LINE・メールで随時相談OK" },
  { label: "面談 月1回〜", desc: "Google Meet 画面共有OK" },
  { label: "改善施策リスト", desc: "優先順位つきTo-Doを毎月更新" },
];

const comparisons = [
  { item: "月額費用", us: "2万円〜", them: "20〜50万円", freelance: "案件ごと" },
  { item: "初期費用", us: "10万円", them: "50〜100万円", freelance: "なし" },
  { item: "契約期間", us: "縛りなし", them: "6ヶ月〜1年", freelance: "案件単位" },
  { item: "対応範囲", us: "Web・AI・マーケ全般", them: "専門領域のみ", freelance: "依頼範囲のみ" },
  { item: "相談のしやすさ", us: "チャットでいつでも", them: "月1回の定例のみ", freelance: "都度見積もり" },
  { item: "AI活用の知見", us: "最新ツールに精通", them: "担当者による", freelance: "個人による" },
];

const initCosts = [
  { label: "現状分析・ヒアリング", desc: "サイト・業務フローの棚卸し" },
  { label: "課題整理・優先順位づけ", desc: "データに基づく改善点の特定" },
  { label: "改善ロードマップ作成", desc: "3ヶ月先までの具体的な施策計画" },
  { label: "初期環境構築", desc: "分析ツール設定・AI環境のセットアップ" },
];
---

<section id="services" class="svc-section">
  <div class="svc-inner">

    <div class="svc-header">
      <div class="svc-header-text">
        <p class="sec-tag">SERVICE</p>
        <h2 class="svc-title">Web・AIの専門家が<span>月額2万円〜で伴走</span></h2>
      </div>
      <div class="svc-header-body">
        <p>「AIを導入したいけど、何から始めればいいか分からない」「Webサイトの改善を相談できる相手がいない」...そんな課題を、オンライン完結の顧問サービスで解決します。</p>
      </div>
    </div>

    <div class="svc-grid">
      {services.map((s) => (
        <div class="svc-card">
          <p class="svc-card-name">{s.name}</p>
          <p class="svc-card-title">{s.title}</p>
          <p class="svc-card-models">{s.models}</p>
        </div>
      ))}
    </div>

    <div class="price-card">
      <p class="sec-tag">PRICING</p>
      <h3 class="price-card-title">Web AI顧問</h3>
      <p class="price-card-desc">外部コンサルの1/10以下のコストで、Web戦略からAI活用まで何でも相談できる。いつでも解約可能。</p>
      <div class="price-nums">
        <div class="price-main">
          <p class="price-label">MONTHLY</p>
          <p class="price-value">20,000<span>円〜</span></p>
        </div>
        <div class="price-details">
          <p>初期費用 100,000円（税別）</p>
          <p>月2回 40,000円 / 月4回 80,000円</p>
          <p>契約期間の縛りなし</p>
          <p class="price-note">※今後価格改定を予定しています</p>
        </div>
      </div>
    </div>

    <div class="dlv-section">
      <p class="sec-tag">DELIVERABLES</p>
      <h3 class="section-h3">毎月届くもの</h3>
      <div class="dlv-grid">
        {deliverables.map((d) => (
          <div class="dlv-card">
            <p class="dlv-card-label">{d.label}</p>
            <p class="dlv-card-desc">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="init-section">
      <p class="sec-tag">INITIAL SETUP</p>
      <h3 class="section-h3">初期費用10万円に含まれるもの</h3>
      <div class="init-grid">
        {initCosts.map((c, i) => (
          <div class="init-card">
            <span class="init-num">{i + 1}</span>
            <div>
              <p class="init-card-label">{c.label}</p>
              <p class="init-card-desc">{c.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="comp-section">
      <p class="sec-tag">COMPARISON</p>
      <h3 class="section-h3">他の選択肢との比較</h3>
      <div class="comp-table-wrap">
        <table class="comp-table">
          <thead>
            <tr>
              <th></th>
              <th class="comp-us">Web AI顧問</th>
              <th>外部コンサル</th>
              <th>フリーランス</th>
            </tr>
          </thead>
          <tbody>
            {comparisons.map((row) => (
              <tr>
                <td class="comp-item">{row.item}</td>
                <td class="comp-us-val">{row.us}</td>
                <td class="comp-other">{row.them}</td>
                <td class="comp-other">{row.freelance}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="svc-cta">
      <a href="/lp/ai-assessment/" class="btn-primary">
        <span>AI活用度を診断する</span>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="/lp/roi-calculator/" class="btn-outline">コスト試算</a>
    </div>

  </div>
</section>

<style>
  .sec-tag {
    font-size: 10px;
    color: #cc8800;
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .section-h3 {
    font-size: 20px;
    font-weight: 900;
    font-style: italic;
    color: #111;
    margin-bottom: 1.5rem;
  }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 10px;
    background: #111; color: #fff;
    font-size: 11px; font-weight: 700; letter-spacing: 3px;
    text-transform: uppercase; text-decoration: none; padding: 13px 28px;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: #cc8800; }
  .btn-outline {
    display: inline-flex; align-items: center;
    border: 1px solid rgba(0,0,0,0.4); color: rgba(0,0,0,0.5);
    font-size: 11px; font-weight: 500; letter-spacing: 3px;
    text-transform: uppercase; text-decoration: none; padding: 13px 28px;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-outline:hover { border-color: #111; color: #111; }

  .svc-section {
    padding: 6rem 1.5rem;
    background: #fff;
    border-bottom: 1px solid #e8e8e8;
  }
  .svc-inner { max-width: 960px; margin: 0 auto; }

  .svc-header {
    display: grid; grid-template-columns: 1fr 1fr; gap: 4rem;
    align-items: start; margin-bottom: 4rem;
  }
  .svc-title {
    font-size: clamp(22px, 3vw, 28px); font-weight: 900; font-style: italic;
    color: #111; line-height: 1.4;
  }
  .svc-title span {
    display: block; font-size: clamp(14px, 2vw, 18px); font-weight: 300;
    font-style: normal; color: rgba(0,0,0,0.45); letter-spacing: 2px; margin-top: 0.25rem;
  }
  .svc-header-body p { font-size: 13px; color: rgba(0,0,0,0.6); line-height: 2; }

  .svc-grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 1px; background: #e8e8e8; margin-bottom: 4rem;
  }
  .svc-card { padding: 1.5rem; background: #fff; transition: background 0.2s; }
  .svc-card:hover { background: #fafafa; }
  .svc-card-name {
    font-size: 10px; letter-spacing: 3px; color: rgba(0,0,0,0.4);
    text-transform: uppercase; margin-bottom: 0.5rem; transition: color 0.2s;
  }
  .svc-card:hover .svc-card-name { color: #cc8800; }
  .svc-card-title { font-size: 15px; color: #111; font-weight: 600; margin-bottom: 0.5rem; }
  .svc-card-models { font-size: 11px; color: rgba(0,0,0,0.45); line-height: 1.6; }

  .price-card {
    border: 1px solid #e8e8e8; padding: 4rem 3rem; margin-bottom: 4rem; background: #fff;
  }
  .price-card-title {
    font-size: clamp(20px, 3vw, 26px); font-weight: 900; font-style: italic;
    color: #111; margin-bottom: 0.75rem;
  }
  .price-card-desc {
    font-size: 13px; color: rgba(0,0,0,0.55); line-height: 1.8;
    margin-bottom: 2rem; max-width: 500px;
  }
  .price-nums { display: flex; align-items: flex-end; gap: 3rem; }
  .price-label {
    font-size: 9px; letter-spacing: 4px; color: rgba(0,0,0,0.4);
    text-transform: uppercase; margin-bottom: 4px;
  }
  .price-value {
    font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 900; font-style: italic;
    color: #cc8800; line-height: 1;
  }
  .price-value span { font-size: 14px; font-style: normal; font-weight: 500; }
  .price-details { font-size: 11px; color: rgba(0,0,0,0.4); line-height: 1.8; }
  .price-note { font-size: 10px; color: rgba(0,0,0,0.25); margin-top: 4px; }

  .dlv-section { margin-bottom: 4rem; }
  .dlv-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 1px; background: #e8e8e8;
  }
  .dlv-card { background: #fff; padding: 1.25rem; }
  .dlv-card-label { font-size: 13px; font-weight: 700; color: #111; margin-bottom: 4px; }
  .dlv-card-desc { font-size: 11px; color: rgba(0,0,0,0.45); line-height: 1.5; }

  .init-section { margin-bottom: 4rem; }
  .init-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: #e8e8e8; }
  .init-card {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 1.25rem; background: #fff;
  }
  .init-num {
    width: 24px; height: 24px; background: #111; color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; flex-shrink: 0;
  }
  .init-card-label { font-size: 14px; font-weight: 600; color: #111; }
  .init-card-desc { font-size: 12px; color: rgba(0,0,0,0.45); margin-top: 2px; }

  .comp-section { margin-bottom: 4rem; }
  .comp-table-wrap { border: 1px solid #e8e8e8; overflow-x: auto; }
  .comp-table { width: 100%; font-size: 13px; border-collapse: collapse; }
  .comp-table th {
    padding: 14px 16px; font-size: 10px; font-weight: 600;
    letter-spacing: 2px; text-transform: uppercase;
    background: #111; color: rgba(255,255,255,0.6); text-align: center;
  }
  .comp-table th:first-child { text-align: left; }
  .comp-us { color: #cc8800 !important; }
  .comp-table td { padding: 12px 16px; border-bottom: 1px solid #e8e8e8; }
  .comp-item { font-weight: 500; color: rgba(0,0,0,0.6); }
  .comp-us-val { text-align: center; font-weight: 700; color: #cc8800; }
  .comp-other { text-align: center; color: rgba(0,0,0,0.3); }

  .svc-cta {
    text-align: center; display: flex; flex-wrap: wrap;
    align-items: center; justify-content: center; gap: 1rem;
  }

  @media (max-width: 768px) {
    .svc-header { grid-template-columns: 1fr; gap: 1.5rem; }
    .svc-grid { grid-template-columns: 1fr; }
    .price-card { padding: 3rem 1.5rem; }
    .price-nums { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
    .dlv-grid { grid-template-columns: repeat(2, 1fr); }
    .init-grid { grid-template-columns: 1fr; }
  }
</style>

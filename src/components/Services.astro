---

<section id="services" class="relative py-16 md:py-20 lg:py-24 bg-surface-alt">
  <div class="max-w-6xl mx-auto px-4 md:px-6 lg:px-8">
    <div class="text-center mb-12 md:mb-16 animate-on-scroll">
      <p class="text-primary-500 text-sm font-semibold tracking-[.2em] uppercase mb-3">Service</p>
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
        Web・AIの専門家が、<span class="marker-highlight">月額2万円</span>で伴走
      </h2>
      <p class="mt-4 text-sm md:text-base text-text-secondary max-w-2xl mx-auto leading-relaxed">
        「AIを導入したいけど、何から始めればいいか分からない」「Webサイトの改善を相談できる相手がいない」…そんな課題を、オンライン完結の顧問サービスで解決します。
      </p>
    </div>

    <!-- Main Service Card -->
    <div class="animate-on-scroll max-w-4xl mx-auto">
      <div class="block group relative rounded-2xl overflow-hidden bg-gradient-to-r from-amber-500 to-orange-600 p-[2px]">
        <div class="relative rounded-[14px] bg-white px-6 py-8 md:px-10 md:py-10">
          <div class="flex flex-col md:flex-row items-center gap-6 md:gap-10">
            <div class="w-16 h-16 md:w-20 md:h-20 rounded-2xl bg-gradient-to-br from-amber-500 to-orange-600 flex items-center justify-center shrink-0">
              <svg class="w-8 h-8 md:w-10 md:h-10 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5l4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />
              </svg>
            </div>

            <div class="flex-1 text-center md:text-left">
              <p class="text-xs font-semibold text-amber-600 tracking-wider uppercase mb-2">Web AI Advisory</p>
              <h3 class="text-2xl md:text-3xl font-bold text-text-primary mb-3">Web AI顧問</h3>
              <p class="text-sm md:text-base text-text-secondary leading-relaxed">
                外部コンサルの<strong class="text-text-primary">1/10以下のコスト</strong>で、Web戦略からAI活用まで何でも相談できる。初期費用10万円＋月額2万円で、御社専属のWeb・AI参謀がつきます。いつでも解約可能。
              </p>
            </div>

            <div class="text-center shrink-0">
              <p class="text-sm text-text-muted">月額</p>
              <p class="text-4xl md:text-5xl font-black bg-gradient-to-r from-amber-500 to-orange-600 bg-clip-text text-transparent">20,000<span class="text-lg">円〜</span></p>
              <p class="text-[11px] text-text-muted mt-1">初期費用 100,000円（税別）</p>
              <p class="text-[10px] text-text-muted">契約期間の縛りなし</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- What's included -->
    <div class="mt-12 md:mt-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-4xl mx-auto">
      {features.map((feature, i) => (
        <div
          class="animate-on-scroll text-center p-5 rounded-xl bg-white border border-border"
          style={`animation-delay: ${i * 0.1}s`}
        >
          <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
            </svg>
          </div>
          <h4 class="text-sm font-bold text-text-primary mb-1.5">{feature.title}</h4>
          <p class="text-xs text-text-secondary leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>

    <!-- 毎月届くもの -->
    <div class="mt-12 md:mt-16 max-w-4xl mx-auto animate-on-scroll">
      <h3 class="text-lg md:text-xl font-bold text-text-primary text-center mb-6">
        毎月届くもの
      </h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {deliverables.map((d) => (
          <div class="flex items-start gap-3 p-4 rounded-xl bg-white border border-border">
            <div class="w-9 h-9 rounded-lg bg-amber-50 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 text-amber-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={d.icon} />
              </svg>
            </div>
            <div>
              <p class="text-sm font-bold text-text-primary">{d.label}</p>
              <p class="text-xs text-text-secondary mt-0.5">{d.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 初期費用の内訳 -->
    <div class="mt-12 md:mt-16 max-w-3xl mx-auto animate-on-scroll">
      <h3 class="text-lg md:text-xl font-bold text-text-primary text-center mb-6">
        初期費用10万円に含まれるもの
      </h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {initCosts.map((c, i) => (
          <div class="flex items-start gap-3 p-4 rounded-xl bg-white border border-border">
            <div class="w-7 h-7 rounded-full bg-amber-500 text-white flex items-center justify-center text-xs font-bold shrink-0">{i + 1}</div>
            <div>
              <p class="text-sm font-bold text-text-primary">{c.label}</p>
              <p class="text-xs text-text-secondary mt-0.5">{c.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 他社比較表 -->
    <div class="mt-12 md:mt-16 max-w-3xl mx-auto animate-on-scroll">
      <h3 class="text-lg md:text-xl font-bold text-text-primary text-center mb-6">
        他の選択肢との比較
      </h3>
      <div class="overflow-x-auto rounded-xl border border-border">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-primary-950 text-white">
              <th class="py-3 px-4 text-left font-medium"></th>
              <th class="py-3 px-4 text-center font-bold">
                <span class="text-accent-400">Web AI顧問</span>
              </th>
              <th class="py-3 px-4 text-center font-medium">外部コンサル</th>
              <th class="py-3 px-4 text-center font-medium">フリーランス</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            {comparisons.map((row, i) => (
              <tr class={i < comparisons.length - 1 ? "border-b border-border" : ""}>
                <td class="py-3 px-4 font-medium text-text-secondary">{row.item}</td>
                <td class="py-3 px-4 text-center font-bold text-amber-600">{row.us}</td>
                <td class="py-3 px-4 text-center text-text-muted">{row.them}</td>
                <td class="py-3 px-4 text-center text-text-muted">{row.freelance}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-10 text-center animate-on-scroll">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/lp/ai-assessment/" class="inline-flex items-center gap-2 bg-gradient-to-r from-amber-500 to-orange-600 text-white font-bold px-7 py-3.5 rounded-full hover:shadow-lg transition-shadow">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
          </svg>
          <span>AI活用度を診断する</span>
        </a>
        <a href="/lp/roi-calculator/" class="inline-flex items-center gap-2 border-2 border-amber-500 text-amber-600 font-bold px-7 py-3.5 rounded-full hover:bg-amber-50 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <span>コスト削減額を試算する</span>
        </a>
      </div>
      <p class="text-xs text-text-muted mt-3">どちらも約2分・登録不要で完了します。</p>
    </div>
  </div>
</section>

---
const boxes = [
  {
    href: "/tools/ai-assessment/",
    label: "無料AI診断",
    title: "AI活用度を診断する",
    desc: "10問の質問に答えるだけで、御社のAI活用レベルと具体的な改善ポイントが分かります。",
    time: "約2分",
    color: "blue",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />`,
  },
  {
    href: "/tools/roi-calculator/",
    label: "無料シミュレーター",
    title: "コスト削減額を試算する",
    desc: "業種と従業員数を入力するだけで、AI導入による年間コスト削減額をその場で概算できます。",
    time: "約1分",
    color: "emerald",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />`,
  },
];

const colorMap: Record<string, { bg: string; border: string; label: string; hover: string; iconBg: string; badge: string }> = {
  blue: {
    bg: "bg-blue-50",
    border: "border-blue-200 hover:border-blue-400",
    label: "text-blue-600",
    hover: "group-hover:text-blue-600",
    iconBg: "bg-blue-500",
    badge: "bg-blue-100 text-blue-600",
  },
  emerald: {
    bg: "bg-emerald-50",
    border: "border-emerald-200 hover:border-emerald-400",
    label: "text-emerald-600",
    hover: "group-hover:text-emerald-600",
    iconBg: "bg-emerald-500",
    badge: "bg-emerald-100 text-emerald-600",
  },
};
---

<section class="relative -mt-8 z-30 pb-8 md:pb-12">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-4 md:gap-6">
      {boxes.map((box) => {
        const c = colorMap[box.color];
        return (
          <a
            href={box.href}
            class:list={[
              "group relative flex flex-col gap-4 p-6 md:p-7 rounded-2xl border-2 bg-white transition-all duration-200",
              "shadow-md hover:shadow-xl hover:-translate-y-1",
              c.border,
            ]}
          >
            <div class="flex items-start gap-4">
              <div class:list={["w-12 h-12 rounded-xl flex items-center justify-center shrink-0", c.iconBg]}>
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <Fragment set:html={box.icon} />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <span class:list={["inline-block text-[11px] font-bold tracking-wide uppercase mb-1", c.label]}>
                  {box.label}
                </span>
                <h3 class:list={["text-lg md:text-xl font-black text-gray-900 leading-tight transition-colors", c.hover]}>
                  {box.title}
                </h3>
              </div>
            </div>

            <p class="text-sm text-gray-500 leading-relaxed">
              {box.desc}
            </p>

            <div class="flex items-center justify-between mt-auto pt-2">
              <div class="flex items-center gap-3 text-xs text-gray-400">
                <span class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                  {box.time}
                </span>
                <span class:list={["px-2 py-0.5 rounded-full text-[10px] font-bold", c.badge]}>
                  登録不要
                </span>
              </div>
              <span class:list={["flex items-center gap-1 text-xs font-bold transition-colors", c.label]}>
                試してみる
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

---
const navLinks = [
  { label: "サービス", href: "/#services" },
  { label: "会社概要", href: "/company/" },
  { label: "代表挨拶", href: "/greeting/" },
  { label: "採用情報", href: "/recruit/" },
  { label: "ブログ", href: "/blog/" },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="header-logo">
      <svg class="logo-svg" viewBox="0 0 127.6 17" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="株式会社37Design"><g fill="#111"><path d="M44.9,3.3h-9.6v1h8.8l-8.7,10.2h1.4l8.6-10.2c0.2-0.2,0.2-0.3,0.2-0.5C45.6,3.6,45.4,3.3,44.9,3.3z"/><path d="M17,3.9L17,3.9L17,3.9l-6.3-3l-6.3,3l-1.5,6.8l4.3,5.4h0l0,0l0,0h6.9l4.3-5.4L17,3.9L17,3.9z M5,4.4l5.7-2.7 l5.5,2.7l-12.6,6L5,4.4z M7.2,15l-3.3-4.1l10.7-5.1L7.2,15z M17.8,10.5l-3.9,4.9h-6l8.6-10.8L17.8,10.5z"/><path d="M31.3,8.7c1.2-0.2,2.1-1,2.1-2.5c0-1.9-1.3-2.8-3.4-2.8h-7.3v1h6.9c1.7,0,2.7,0.6,2.7,2c0,1.4-0.8,2-2.4,2 h-4.7v1h4.8c1.6,0,2.5,0.7,2.5,2.1c0,1.3-1.1,2.1-2.9,2.1h-7v1h7.5c2.2,0,3.4-1.4,3.4-3.1C33.6,9.8,32.7,8.9,31.3,8.7z"/><path d="M53.5,3.3h-6.3v11.2h6.3c3,0,5.2-2.5,5.2-5.7C58.7,5.6,56.5,3.3,53.5,3.3z M53.5,13.5h-5.2V4.4h5.2 c2.4,0,4.2,1.9,4.2,4.5C57.7,11.5,55.9,13.5,53.5,13.5z"/><polygon points="61.7,4.4 70.3,4.4 70.3,3.3 60.7,3.3 60.7,14.5 70.3,14.5 70.3,13.5 61.7,13.5"/><rect x="85.9" y="3.3" width="1" height="11.2"/><path d="M113,3.3V13l-9.1-9.6c-0.2-0.2-0.3-0.3-0.5-0.3c-0.4,0-0.6,0.3-0.6,0.7v10.7h1V4.8l9.1,9.6 c0.2,0.2,0.4,0.3,0.5,0.3c0.3,0,0.6-0.2,0.6-0.6V3.3H113z"/><path d="M94,9.3h5.7v4.2h-5.5c-2.4,0-4.2-2-4.2-4.6c0-2.7,1.8-4.5,4.2-4.5h5.9v-1h-5.9c-3,0-5.3,2.2-5.3,5.5 c0,3.3,2.2,5.7,5.3,5.7h6.5V8.3H94V9.3z"/><rect x="63.2" y="8.3" width="6.7" height="1"/><path d="M80.6,8.3h-5.3c-1.3,0-2.1-0.8-2.1-2c0-1.2,0.7-2,2.1-2h8v-1h-8c-2,0-3.1,1.3-3.1,3c0,1.7,1.2,3,3.1,3h5.3 c1.4,0,2.2,0.7,2.2,2.1c0,1.2-0.7,2.1-2.2,2.1h-8.3v1h8.3c2.1,0,3.2-1.3,3.2-3.1C83.8,9.3,82.7,8.3,80.6,8.3z"/></g></svg>
    </a>

    <!-- Desktop Nav -->
    <nav class="desktop-nav">
      {navLinks.map((link) => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
      <a href="https://cal.37d.jp/37design/ai%E7%9B%B8%E8%AB%87" target="_blank" rel="noopener noreferrer" class="nav-cta">
        <span>無料面談</span>
        <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </nav>

    <!-- Mobile Hamburger -->
    <button id="menu-btn" class="menu-btn" aria-expanded="false" aria-controls="mobile-menu" aria-label="メニューを開く">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <nav id="mobile-menu" class="mobile-menu">
    {navLinks.map((link) => (
      <a href={link.href} class="mobile-link">{link.label}</a>
    ))}
    <a href="https://cal.37d.jp/37design/ai%E7%9B%B8%E8%AB%87" target="_blank" rel="noopener noreferrer" class="nav-cta" style="margin-top:0.5rem;">
      <span>無料面談を予約</span>
      <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #fff;
    border-bottom: 1px solid #e8e8e8;
  }
  .header-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .header-logo { display: flex; align-items: center; text-decoration: none; }
  .logo-svg { height: 15px; width: auto; }

  .desktop-nav {
    display: none;
    align-items: center;
    gap: 2rem;
  }
  .nav-link {
    color: #111;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-link:hover { color: #cc8800; }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #111;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    text-decoration: none;
    padding: 10px 24px;
    transition: background 0.2s;
  }
  .nav-cta:hover { background: #cc8800; }

  .menu-btn {
    display: flex;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 8px;
    background: none;
    border: none;
  }
  .bar {
    display: block;
    width: 22px;
    height: 1.5px;
    background: #111;
    transition: transform 0.3s, opacity 0.3s;
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    background: #fff;
    border-top: 1px solid #e8e8e8;
    padding: 1rem 1.5rem 1.5rem;
  }
  .mobile-link {
    display: block;
    padding: 12px 0;
    color: #111;
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    border-bottom: 1px solid #f0f0f0;
  }
  .mobile-link:hover { color: #cc8800; }

  @media (min-width: 769px) {
    .desktop-nav { display: flex; }
    .menu-btn { display: none; }
  }
</style>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const bars = document.querySelectorAll('.bar');
  let open = false;

  btn?.addEventListener('click', () => {
    open = !open;
    if (menu) menu.style.display = open ? 'flex' : 'none';
    btn?.setAttribute('aria-expanded', String(open));
    btn?.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');
    if (bars.length >= 3) {
      (bars[0] as HTMLElement).style.transform = open ? 'translateY(6.5px) rotate(45deg)' : '';
      (bars[1] as HTMLElement).style.opacity = open ? '0' : '';
      (bars[2] as HTMLElement).style.transform = open ? 'translateY(-6.5px) rotate(-45deg)' : '';
    }
  });

  document.addEventListener('click', (e) => {
    if (open && !menu?.contains(e.target as Node) && !btn?.contains(e.target as Node)) {
      open = false;
      if (menu) menu.style.display = 'none';
      btn?.setAttribute('aria-expanded', 'false');
      if (bars.length >= 3) {
        (bars[0] as HTMLElement).style.transform = '';
        (bars[1] as HTMLElement).style.opacity = '';
        (bars[2] as HTMLElement).style.transform = '';
      }
    }
  });

  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      open = false;
      if (menu) menu.style.display = 'none';
    });
  });
</script>

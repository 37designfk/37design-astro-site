---
const navLinks = [
  { label: "サービス", href: "/#services" },
  { label: "会社概要", href: "/company/" },
  { label: "代表挨拶", href: "/greeting/" },
  { label: "採用情報", href: "/recruit/" },
  { label: "ニュースレター", href: "/newsletter/" },
];

const socialLinks = [
  { label: "Facebook", href: "https://www.facebook.com/37designfk", icon: "M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" },
  { label: "Instagram", href: "https://www.instagram.com/37designfk/", icon: "M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 01-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 017.8 2zm4.2 5a5 5 0 100 10 5 5 0 000-10zm0 2a3 3 0 110 6 3 3 0 010-6zm5.2-3.5a1.2 1.2 0 100 2.4 1.2 1.2 0 000-2.4z" },
  { label: "X", href: "https://twitter.com/37designfk", icon: "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-primary-950">
  <div class="max-w-6xl mx-auto px-4 md:px-6 lg:px-8 flex items-center justify-between h-16">
    <!-- Logo -->
    <a href="/" class="flex items-center">
      <svg class="h-6 md:h-7 w-auto" viewBox="0 0 127.6 17" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="株式会社37Design"><defs><linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#ffe566"/><stop offset="30%" style="stop-color:#ffdc40"/><stop offset="60%" style="stop-color:#f5c518"/><stop offset="100%" style="stop-color:#d4a520"/></linearGradient></defs><g fill="url(#goldGrad)"><path d="M44.9,3.3h-9.6v1h8.8l-8.7,10.2h1.4l8.6-10.2c0.2-0.2,0.2-0.3,0.2-0.5C45.6,3.6,45.4,3.3,44.9,3.3z"/><path d="M17,3.9L17,3.9L17,3.9l-6.3-3l-6.3,3l-1.5,6.8l4.3,5.4h0l0,0l0,0h6.9l4.3-5.4L17,3.9L17,3.9z M5,4.4l5.7-2.7 l5.5,2.7l-12.6,6L5,4.4z M7.2,15l-3.3-4.1l10.7-5.1L7.2,15z M17.8,10.5l-3.9,4.9h-6l8.6-10.8L17.8,10.5z"/><path d="M31.3,8.7c1.2-0.2,2.1-1,2.1-2.5c0-1.9-1.3-2.8-3.4-2.8h-7.3v1h6.9c1.7,0,2.7,0.6,2.7,2c0,1.4-0.8,2-2.4,2 h-4.7v1h4.8c1.6,0,2.5,0.7,2.5,2.1c0,1.3-1.1,2.1-2.9,2.1h-7v1h7.5c2.2,0,3.4-1.4,3.4-3.1C33.6,9.8,32.7,8.9,31.3,8.7z"/><path d="M53.5,3.3h-6.3v11.2h6.3c3,0,5.2-2.5,5.2-5.7C58.7,5.6,56.5,3.3,53.5,3.3z M53.5,13.5h-5.2V4.4h5.2 c2.4,0,4.2,1.9,4.2,4.5C57.7,11.5,55.9,13.5,53.5,13.5z"/><polygon points="61.7,4.4 70.3,4.4 70.3,3.3 60.7,3.3 60.7,14.5 70.3,14.5 70.3,13.5 61.7,13.5"/><rect x="85.9" y="3.3" width="1" height="11.2"/><path d="M113,3.3V13l-9.1-9.6c-0.2-0.2-0.3-0.3-0.5-0.3c-0.4,0-0.6,0.3-0.6,0.7v10.7h1V4.8l9.1,9.6 c0.2,0.2,0.4,0.3,0.5,0.3c0.3,0,0.6-0.2,0.6-0.6V3.3H113z"/><path d="M94,9.3h5.7v4.2h-5.5c-2.4,0-4.2-2-4.2-4.6c0-2.7,1.8-4.5,4.2-4.5h5.9v-1h-5.9c-3,0-5.3,2.2-5.3,5.5 c0,3.3,2.2,5.7,5.3,5.7h6.5V8.3H94V9.3z"/><rect x="63.2" y="8.3" width="6.7" height="1"/><path d="M80.6,8.3h-5.3c-1.3,0-2.1-0.8-2.1-2c0-1.2,0.7-2,2.1-2h8v-1h-8c-2,0-3.1,1.3-3.1,3c0,1.7,1.2,3,3.1,3h5.3 c1.4,0,2.2,0.7,2.2,2.1c0,1.2-0.7,2.1-2.2,2.1h-8.3v1h8.3c2.1,0,3.2-1.3,3.2-3.1C83.8,9.3,82.7,8.3,80.6,8.3z"/></g></svg>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-6">
      {navLinks.map((link) => (
        <a href={link.href} class="text-sm font-medium text-white/80 hover:text-white transition-colors">
          {link.label}
        </a>
      ))}
      <div class="flex items-center gap-3 ml-2">
        {socialLinks.map((s) => (
          <a href={s.href} target="_blank" rel="noopener noreferrer" class="text-white/60 hover:text-white transition-colors" aria-label={s.label}>
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d={s.icon} /></svg>
          </a>
        ))}
      </div>
      <a
        href="/lp/ai-assessment/"
        class="ml-2 inline-flex items-center gap-1.5 px-4 py-2 bg-accent-400 text-primary-900 text-sm font-bold rounded-full hover:bg-accent-300 transition-colors"
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" /></svg>
        AI診断
      </a>
      <a
        href="/lp/roi-calculator/"
        class="inline-flex items-center gap-1.5 px-4 py-2 border border-accent-400/50 text-accent-400 text-sm font-bold rounded-full hover:bg-accent-400/10 transition-colors"
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
        コスト試算
      </a>
    </nav>

    <!-- Mobile Hamburger -->
    <button
      id="menu-button"
      type="button"
      class="lg:hidden flex flex-col gap-1.5 cursor-pointer p-2"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="メニューを開く"
    >
      <span class="block w-6 h-0.5 bg-white transition-all"></span>
      <span class="block w-6 h-0.5 bg-white transition-all"></span>
      <span class="block w-6 h-0.5 bg-white transition-all"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <nav id="mobile-menu" class="hidden lg:hidden flex-col bg-primary-950 border-t border-white/10 px-4 pb-4">
    {navLinks.map((link) => (
      <a href={link.href} class="py-3 text-sm font-medium text-white/80 hover:text-white border-b border-white/10">
        {link.label}
      </a>
    ))}
    <div class="flex items-center gap-4 py-3">
      {socialLinks.map((s) => (
        <a href={s.href} target="_blank" rel="noopener noreferrer" class="text-white/60 hover:text-white transition-colors" aria-label={s.label}>
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d={s.icon} /></svg>
        </a>
      ))}
    </div>
    <div class="flex gap-3 mt-3">
      <a
        href="/lp/ai-assessment/"
        class="flex-1 inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-accent-400 text-primary-900 text-sm font-bold rounded-full hover:bg-accent-300 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" /></svg>
        AI診断
      </a>
      <a
        href="/lp/roi-calculator/"
        class="flex-1 inline-flex items-center justify-center gap-2 px-5 py-2.5 border border-accent-400/50 text-accent-400 text-sm font-bold rounded-full hover:bg-accent-400/10 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
        コスト試算
      </a>
    </div>
  </nav>
</header>

<!-- Spacer for fixed header -->
<div class="h-16"></div>

<script>
  const menuButton = document.getElementById("menu-button");
  const mobileMenu = document.getElementById("mobile-menu");

  if (menuButton && mobileMenu) {
    const setMenuState = (open) => {
      menuButton.setAttribute("aria-expanded", String(open));
      menuButton.setAttribute("aria-label", open ? "メニューを閉じる" : "メニューを開く");
      mobileMenu.classList.toggle("hidden", !open);
      mobileMenu.classList.toggle("flex", open);
    };

    const toggleMenu = () => {
      const isOpen = menuButton.getAttribute("aria-expanded") === "true";
      setMenuState(!isOpen);
    };

    setMenuState(false);
    menuButton.addEventListener("click", toggleMenu);

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") setMenuState(false);
    });

    document.addEventListener("click", (event) => {
      const target = event.target;
      const clickedOutside = !mobileMenu.contains(target) && !menuButton.contains(target);
      if (clickedOutside) setMenuState(false);
    });

    mobileMenu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setMenuState(false));
    });
  }
</script>

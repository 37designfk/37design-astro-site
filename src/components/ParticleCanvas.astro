---
// Lightweight canvas starfield for hero sections
---

<canvas id="particle-canvas" class="absolute inset-0 w-full h-full pointer-events-none z-[1]" aria-hidden="true"></canvas>

<script is:inline>
(function() {
  var startFn = function() {
  var canvas = document.getElementById('particle-canvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');

  var width, height, dpr;
  var particles = [];
  var animId;
  var lastTime = 0;

  var isMobile = window.innerWidth < 768;
  var COUNT = isMobile ? 30 : 80;
  var MAX_Z = 1000;
  var SPEED = 0.3;
  var FOV = 256;

  function resize() {
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    var rect = canvas.parentElement.getBoundingClientRect();
    width = rect.width;
    height = rect.height;
    canvas.width = width * dpr;
    canvas.height = height * dpr;
    canvas.style.width = width + 'px';
    canvas.style.height = height + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function createParticle(randomZ) {
    var spread = Math.max(width, height);
    return {
      x: (Math.random() - 0.5) * spread,
      y: (Math.random() - 0.5) * spread,
      z: randomZ ? Math.random() * MAX_Z + 1 : MAX_Z + Math.random() * 200,
      a: Math.random() > 0.7 ? 'rgba(255,220,64,' : 'rgba(255,255,255,'
    };
  }

  function init() {
    resize();
    particles = [];
    for (var i = 0; i < COUNT; i++) particles.push(createParticle(true));
  }

  function animate(time) {
    var dt = lastTime ? Math.min(time - lastTime, 50) : 16.67;
    lastTime = time;
    var zStep = SPEED * dt;
    var cx = width / 2;
    var cy = height / 2;

    ctx.clearRect(0, 0, width, height);

    for (var i = 0; i < particles.length; i++) {
      var p = particles[i];
      var k = FOV / p.z;
      var sx = cx + p.x * k;
      var sy = cy + p.y * k;
      var proximity = 1 - p.z / MAX_Z;
      var size = Math.max(0.3, proximity * 2.5);
      var alpha = Math.min(1, Math.max(0.05, proximity * 1.2));

      ctx.beginPath();
      ctx.arc(sx, sy, size, 0, 6.283);
      ctx.fillStyle = p.a + alpha + ')';
      ctx.fill();

      p.z -= zStep;
      if (p.z <= 0.5 || sx < -50 || sx > width + 50 || sy < -50 || sy > height + 50) {
        var np = createParticle(false);
        p.x = np.x; p.y = np.y; p.z = np.z;
      }
    }

    animId = requestAnimationFrame(animate);
  }

  var resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(resize, 200);
  }, { passive: true });

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  document.addEventListener('visibilitychange', function() {
    if (document.hidden) { cancelAnimationFrame(animId); lastTime = 0; }
    else { lastTime = 0; animId = requestAnimationFrame(animate); }
  });

  var heroObs = new IntersectionObserver(function(entries) {
    if (!entries[0].isIntersecting) { cancelAnimationFrame(animId); lastTime = 0; }
    else { lastTime = 0; animId = requestAnimationFrame(animate); }
  }, { threshold: 0 });

  init();
  animId = requestAnimationFrame(animate);
  if (canvas.parentElement) heroObs.observe(canvas.parentElement);
  };

  if ('requestIdleCallback' in window) requestIdleCallback(startFn, { timeout: 2000 });
  else setTimeout(startFn, 1500);
})();
</script>

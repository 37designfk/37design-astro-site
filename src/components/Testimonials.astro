---
const testimonials = [
  {
    quote: "何から手をつけていいか分からなかったWeb改善が、月1回の面談で着実に進むようになりました。",
    name: "G社 代表取締役",
    industry: "飲食業（従業員12名）",
  },
  {
    quote: "AIツールの選定から使い方まで教えてもらえるので、自社で試行錯誤する時間がゼロになった。",
    name: "H社 営業部長",
    industry: "人材紹介（従業員20名）",
  },
  {
    quote: "月2万円でこの内容は正直驚き。外部コンサルに頼んでいた頃の1/10以下のコストです。",
    name: "I社 代表取締役",
    industry: "士業事務所（従業員6名）",
  },
];
---

<section class="voice-section">
  <div class="voice-inner">
    <p class="sec-tag">VOICE</p>
    <h2 class="voice-title">お客様の声</h2>
    <div class="voice-grid">
      {testimonials.map((t) => (
        <div class="voice-card">
          <p class="voice-quote">{t.quote}</p>
          <div class="voice-meta">
            <p class="voice-name">{t.name}</p>
            <p class="voice-industry">{t.industry}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .sec-tag {
    font-size: 10px;
    color: #cc8800;
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .voice-section {
    padding: 6rem 1.5rem;
    background: #fff;
    border-bottom: 1px solid #e8e8e8;
  }
  .voice-inner { max-width: 960px; margin: 0 auto; }
  .voice-title {
    font-size: 24px; font-weight: 900; font-style: italic;
    color: #111; margin-bottom: 3rem;
  }
  .voice-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1px; background: #e8e8e8;
  }
  .voice-card {
    background: #fff; padding: 2rem;
    display: flex; flex-direction: column; justify-content: space-between;
  }
  .voice-quote {
    font-size: 14px; color: #111; line-height: 1.9;
    margin-bottom: 1.5rem;
  }
  .voice-meta { border-top: 1px solid #e8e8e8; padding-top: 1rem; }
  .voice-name { font-size: 12px; font-weight: 600; color: #111; }
  .voice-industry { font-size: 11px; color: rgba(0,0,0,0.4); margin-top: 2px; }

  @media (max-width: 768px) {
    .voice-grid { grid-template-columns: 1fr; }
  }
</style>

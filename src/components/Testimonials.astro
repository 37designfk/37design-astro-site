---

<section class="py-16 md:py-20 bg-white">
  <div class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8">
    <div class="text-center mb-10 animate-on-scroll">
      <p class="text-primary-500 text-sm font-semibold tracking-[.2em] uppercase mb-3">Voice</p>
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary">お客様の声</h2>
      <p class="text-sm text-text-secondary mt-3">実際のやり取りから、公開可能な声だけを匿名表記で掲載しています。</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {testimonials.map((t, i) => (
        <div
          class="animate-on-scroll relative flex flex-col p-6 rounded-xl bg-surface-alt border border-border"
          style={`animation-delay: ${i * 0.1}s`}
          data-source-id={t.sourceId}
        >
          <svg class="w-8 h-8 text-accent-400/30 mb-3" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>
          <p class="text-base font-bold text-text-primary leading-relaxed mb-3">「{t.quote}」</p>
          <p class="text-xs text-text-secondary leading-relaxed mb-5">{t.context}</p>
          <div class="space-y-2 mb-5 rounded-lg bg-white border border-border p-3">
            <div>
              <p class="text-[10px] font-bold tracking-wide uppercase text-primary-500 mb-0.5">Service</p>
              <p class="text-xs font-bold text-text-primary leading-relaxed">{t.service}</p>
            </div>
            <div>
              <p class="text-[10px] font-bold tracking-wide uppercase text-accent-600 mb-0.5">Outcome</p>
              <p class="text-xs text-text-secondary leading-relaxed">{t.result}</p>
            </div>
          </div>
          <div class="flex items-center gap-3 mt-auto pt-4 border-t border-border">
            <div class={`w-9 h-9 rounded-full bg-gradient-to-br ${t.color} text-white flex items-center justify-center text-[11px] font-bold shrink-0`}>
              {t.avatar}
            </div>
            <div class="min-w-0">
              <p class="text-xs font-bold text-text-primary">{t.name}</p>
              <p class="text-[11px] text-text-muted">{t.industry}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

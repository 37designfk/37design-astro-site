---
const stats = [
  { number: 50, suffix: "+社", label: "CLIENTS" },
  { number: 40, suffix: "%", label: "TIME SAVED" },
  { number: 98, suffix: "%", label: "SATISFACTION" },
  { number: 1, prefix: "最短", suffix: "週間", label: "ONBOARDING" },
];
---

<section id="numbers" class="numbers-section">
  <div class="numbers-inner">
    <div class="numbers-grid">
      {stats.map((stat, i) => (
        <div class="num-card">
          <p class="num-value">
            {stat.prefix && <span class="num-prefix">{stat.prefix}</span>}
            <span class="counter" data-target={stat.number} data-delay={i * 150 + 500}>0</span>{stat.suffix}
          </p>
          <p class="num-label">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .numbers-section {
    padding: 0 1.5rem;
    background: #fff;
  }
  .numbers-inner {
    max-width: 960px;
    margin: 0 auto;
    border-bottom: 1px solid #e8e8e8;
    padding: 3rem 0;
  }
  .numbers-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: #e8e8e8;
  }
  .num-card {
    background: #fff;
    text-align: center;
    padding: 2rem 1rem;
  }
  .num-value {
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 900;
    font-style: italic;
    color: #111;
    line-height: 1;
    margin-bottom: 6px;
  }
  .num-prefix {
    font-size: 14px;
    font-weight: 600;
    font-style: normal;
    color: rgba(0,0,0,0.5);
    margin-right: 2px;
  }
  .num-label {
    font-size: 9px;
    letter-spacing: 4px;
    color: rgba(0,0,0,0.4);
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .numbers-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  const section = document.getElementById("numbers");
  if (section) {
    let fired = false;
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !fired) {
          fired = true;
          obs.disconnect();
          document.querySelectorAll(".counter").forEach((el) => {
            const target = parseInt((el as HTMLElement).dataset.target || "0", 10);
            const delay = parseInt((el as HTMLElement).dataset.delay || "500", 10);
            setTimeout(() => {
              const duration = 1800;
              const start = performance.now();
              const animate = (now: number) => {
                const elapsed = now - start;
                const progress = Math.min(elapsed / duration, 1);
                const eased = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
                el.textContent = Math.floor(eased * target).toString();
                if (progress < 1) requestAnimationFrame(animate);
                else el.textContent = target.toString();
              };
              requestAnimationFrame(animate);
            }, delay);
          });
        }
      });
    }, { threshold: 0.3 });
    obs.observe(section);
  }
</script>

<section id="contact" class="cta-section">
  <div class="cta-inner">
    <p class="sec-tag">CONTACT</p>
    <h2 class="cta-title">まずは無料面談から</h2>
    <p class="cta-desc">「何から始めればいい？」でOKです。Web・AIのお悩みをお聞かせください。</p>

    <div class="cta-actions">
      <a href="https://cal.37d.jp/37design/ai%E7%9B%B8%E8%AB%87" target="_blank" rel="noopener noreferrer" class="btn-primary-lg">
        <span>無料面談を予約する</span>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <div class="cta-meta">
      <span>カレンダーから日時を選ぶだけ</span>
      <span>しつこい営業なし</span>
      <span>面談だけでもOK</span>
    </div>

    <div class="cta-sub">
      <a href="https://jmp9xv65.autosns.app/line" target="_blank" rel="noopener noreferrer" class="sub-link">
        <svg class="line-icon" fill="currentColor" viewBox="0 0 24 24" width="18" height="18"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
        <span>LINEで相談</span>
      </a>
      <a href="tel:080-2412-2556" class="sub-link">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/></svg>
        <span>080-2412-2556</span>
      </a>
    </div>
  </div>
</section>

<style>
  .sec-tag {
    font-size: 10px; color: #cc8800; letter-spacing: 4px;
    text-transform: uppercase; margin-bottom: 0.5rem;
  }
  .cta-section {
    padding: 6rem 1.5rem;
    background: #111;
    color: #fff;
  }
  .cta-inner {
    max-width: 640px; margin: 0 auto; text-align: center;
  }
  .cta-title {
    font-size: clamp(24px, 4vw, 36px); font-weight: 900; font-style: italic;
    color: #fff; margin-bottom: 1rem;
  }
  .cta-desc {
    font-size: 14px; color: rgba(255,255,255,0.5);
    line-height: 1.8; margin-bottom: 3rem;
  }

  .cta-actions { margin-bottom: 1.5rem; }
  .btn-primary-lg {
    display: inline-flex; align-items: center; gap: 10px;
    background: #cc8800; color: #fff;
    font-size: 11px; font-weight: 700; letter-spacing: 3px;
    text-transform: uppercase; text-decoration: none;
    padding: 14px 32px; transition: background 0.2s;
  }
  .btn-primary-lg:hover { background: #e09900; }

  .cta-meta {
    display: flex; flex-wrap: wrap; justify-content: center;
    gap: 1.5rem; margin-bottom: 3rem;
    font-size: 11px; color: rgba(255,255,255,0.35); letter-spacing: 1px;
  }

  .cta-sub {
    display: flex; justify-content: center; gap: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 2rem;
  }
  .sub-link {
    display: inline-flex; align-items: center; gap: 8px;
    color: rgba(255,255,255,0.5); text-decoration: none;
    font-size: 12px; letter-spacing: 1px;
    transition: color 0.2s;
  }
  .sub-link:hover { color: #fff; }
  .line-icon { color: #06C755; }
</style>

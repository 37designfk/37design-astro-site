---
interface Props {
  color1?: string;
  color2?: string;
}

const { color1 = '#f8f9fb' } = Astro.props;
const color2 = color1;
---

<div class="wave-container">
  <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path fill={color2} opacity="0.6" d="M0,50 C160,80 320,20 480,50 C640,80 800,20 960,50 C1120,80 1280,20 1440,50 L1440,120 L0,120 Z" />
    <path fill={color1} d="M0,70 C240,100 480,40 720,70 C960,100 1200,40 1440,70 L1440,120 L0,120 Z" />
  </svg>
</div>

<style>
  .wave-container {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    overflow: hidden;
    line-height: 0;
    z-index: 5;
  }
  .wave-container svg {
    display: block;
    width: 100%;
    height: 80px;
  }
</style>

---
const navLinks = [
  { label: "サービス", href: "/#services" },
  { label: "会社概要", href: "/company/" },
  { label: "代表挨拶", href: "/greeting/" },
  { label: "採用情報", href: "/recruit/" },
  { label: "ブログ", href: "/blog/" },
  { label: "ニュースレター", href: "/newsletter/" },
  { label: "AI活用度診断", href: "/lp/ai-assessment/" },
  { label: "コスト削減シミュレーター", href: "/lp/roi-calculator/" },
];

const socialLinks = [
  { label: "Facebook", href: "https://www.facebook.com/37designfk", icon: "M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" },
  { label: "Instagram", href: "https://www.instagram.com/37designfk/", icon: "M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 01-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 017.8 2zm4.2 5a5 5 0 100 10 5 5 0 000-10zm0 2a3 3 0 110 6 3 3 0 010-6zm5.2-3.5a1.2 1.2 0 100 2.4 1.2 1.2 0 000-2.4z" },
  { label: "X", href: "https://twitter.com/37designfk", icon: "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" },
];
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo">37Design</a>
        <p class="footer-tagline">Web・AIのことは、プロに聞こう。</p>
        <div class="footer-social">
          {socialLinks.map((s) => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}>
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d={s.icon} /></svg>
            </a>
          ))}
        </div>
      </div>

      <div class="footer-nav">
        <p class="footer-nav-title">MENU</p>
        <nav class="footer-links">
          {navLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>
      </div>

      <div class="footer-contact">
        <p class="footer-nav-title">CONNECT</p>
        <div class="footer-contact-links">
          <a href="tel:080-2412-2556">TEL: 080-2412-2556</a>
          <a href="mailto:info@37design.co.jp">info@37design.co.jp</a>
        </div>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="footer-copy">&copy; 2012-2026 株式会社37Design</p>
      <div class="footer-legal">
        <a href="/privacy/">プライバシーポリシー</a>
        <a href="/tokushoho/">特定商取引法表記</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #fff;
    border-top: 1px solid #e8e8e8;
  }
  .footer-inner {
    max-width: 960px; margin: 0 auto; padding: 4rem 1.5rem 3rem;
  }
  .footer-top {
    display: flex; justify-content: space-between;
    align-items: flex-start; gap: 3rem;
  }
  .footer-brand { max-width: 260px; }
  .footer-logo {
    display: inline-block; margin-bottom: 1rem;
    font-size: 18px; font-weight: 900; font-style: italic;
    color: #111; text-decoration: none; letter-spacing: -0.5px;
  }
  .footer-tagline {
    font-size: 12px; color: rgba(0,0,0,0.5); line-height: 1.6;
    margin-bottom: 1rem;
  }
  .footer-social { display: flex; gap: 12px; }
  .footer-social a {
    color: rgba(0,0,0,0.3); transition: color 0.2s;
  }
  .footer-social a:hover { color: #111; }

  .footer-nav-title {
    font-size: 10px; letter-spacing: 3px; color: rgba(0,0,0,0.4);
    text-transform: uppercase; margin-bottom: 1rem;
  }
  .footer-links {
    display: flex; flex-direction: column; gap: 0.6rem;
  }
  .footer-links a {
    font-size: 12px; color: rgba(0,0,0,0.5); text-decoration: none;
    letter-spacing: 1px; transition: color 0.2s;
  }
  .footer-links a:hover { color: #111; }

  .footer-contact-links {
    display: flex; flex-direction: column; gap: 0.6rem;
  }
  .footer-contact-links a {
    font-size: 12px; color: rgba(0,0,0,0.5); text-decoration: none;
    transition: color 0.2s;
  }
  .footer-contact-links a:hover { color: #111; }

  .footer-bottom {
    border-top: 1px solid #e8e8e8;
  }
  .footer-bottom-inner {
    max-width: 960px; margin: 0 auto; padding: 1.25rem 1.5rem;
    display: flex; justify-content: space-between; align-items: center;
  }
  .footer-copy { font-size: 10px; color: rgba(0,0,0,0.3); }
  .footer-legal { display: flex; gap: 1.5rem; }
  .footer-legal a {
    font-size: 10px; color: rgba(0,0,0,0.3); text-decoration: none;
    transition: color 0.2s;
  }
  .footer-legal a:hover { color: #111; }

  @media (max-width: 768px) {
    .footer-top { flex-direction: column; gap: 2rem; }
    .footer-bottom-inner { flex-direction: column; gap: 0.5rem; text-align: center; }
  }
</style>

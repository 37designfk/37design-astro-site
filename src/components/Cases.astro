---
const cases = [
  {
    industry: "EC運営",
    company: "EC運営会社",
    problem: "商品ページの作成・更新に時間がかかり、画像や説明文の制作が属人的になっていた",
    service: "商品ページ生成エディタのプロトタイプ設計",
    outcome: "商品ページ制作の初動を高速化。画像生成も含めて、スタッフレビューに回せる叩き台を短時間で作れる状態へ",
    tags: ["商品ページ生成", "AI顧問", "EC運用"],
    gradient: "from-amber-500 to-orange-600",
    iconBg: "bg-amber-50",
    iconColor: "text-amber-600",
    sourceId: "v-2026-05-001",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12A1.125 1.125 0 0 1 19.75 21H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 6.75h12.974a1.125 1.125 0 0 1 1.12 1.007Z" />`,
  },
  {
    industry: "音声マーケティング",
    company: "音声配信運用代行会社",
    problem: "AI動画生成の品質とスピードが、顧客提案にそのまま使える水準まで届いていなかった",
    service: "MTG中のAI動画プロトタイピング",
    outcome: "その場で提案素材の叩き台を生成。説明だけで終わらず、顧客に見せられるアウトプットを即時に共有",
    tags: ["AI動画生成", "プロトタイピング", "提案支援"],
    gradient: "from-cyan-500 to-blue-700",
    iconBg: "bg-cyan-50",
    iconColor: "text-cyan-600",
    sourceId: "v-2026-05-003",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9A2.25 2.25 0 0 0 13.5 5.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />`,
  },
  {
    industry: "Web制作代理店",
    company: "Web制作代理店",
    problem: "AI領域の知見が顧客提案の弱点になり、Web制作だけでは提案の幅を広げにくかった",
    service: "AI社員による自動診断レポートと共同提案支援",
    outcome: "制作会社の裏側にAI実装パートナーがいる状態を作り、顧客提案時の信頼性と提案範囲を補強",
    tags: ["AIオペレーター", "代理店支援", "診断レポート"],
    gradient: "from-violet-500 to-purple-700",
    iconBg: "bg-violet-50",
    iconColor: "text-violet-600",
    sourceId: "v-2026-05-006",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0A5.971 5.971 0 0 0 6 18.719M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />`,
  },
];

const industries = [
  "不動産", "士業", "飲食", "医療・クリニック", "美容・サロン",
  "建設・工務店", "製造業", "小売・EC", "人材", "コンサル",
  "教育・スクール", "介護・福祉", "IT・SaaS", "その他サービス業",
];

const industryStats = [
  { label: "サービス業", count: "18社" },
  { label: "不動産・建設", count: "9社" },
  { label: "士業・コンサル", count: "8社" },
  { label: "医療・美容", count: "7社" },
  { label: "小売・EC・製造", count: "5社" },
  { label: "その他", count: "3社+" },
];
---

<section id="cases" class="relative py-16 md:py-20 lg:py-24 bg-primary-950">
  <div class="max-w-6xl mx-auto px-4 md:px-6 lg:px-8">
    <div class="text-center mb-12 md:mb-16 animate-on-scroll">
      <p class="text-accent-400 text-sm font-semibold tracking-[.2em] uppercase mb-3">Case Studies</p>
      <h2 class="text-2xl md:text-3xl font-bold text-white">
        導入事例<span class="marker-highlight"> ── こう変わりました</span>
      </h2>
      <p class="text-white/40 text-sm mt-3">
        お客様の声とは別に、実施内容と変化が分かる事例だけを匿名表記で掲載しています
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      {cases.map((c, i) => (
        <div
          class="animate-on-scroll rounded-2xl border border-white/10 overflow-hidden card-hover bg-white shadow-[0_18px_50px_rgba(0,0,0,0.18)]"
          data-anim="scale"
          style={`animation-delay: ${i * 0.08}s`}
        >
          <div class={`h-1.5 bg-gradient-to-r ${c.gradient}`}></div>
          <div class="p-5 md:p-6">
            <!-- Header -->
            <div class="flex items-start gap-3 mb-5">
              <div class={`w-12 h-12 rounded-xl ${c.iconBg} ${c.iconColor} flex items-center justify-center shrink-0`}>
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24">
                  <Fragment set:html={c.icon} />
                </svg>
              </div>
              <div class="min-w-0">
                <span class={`inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold text-white bg-gradient-to-r ${c.gradient}`}>{c.industry}</span>
                <p class="text-base font-black text-text-primary mt-2 leading-tight">{c.company}</p>
              </div>
            </div>

            <!-- Problem → Service → Outcome -->
            <div class="space-y-3.5 mb-5">
              <div class="rounded-xl bg-red-50/70 border border-red-100 p-4">
                <p class="text-xs font-black tracking-wide uppercase text-red-600 mb-1.5">Problem</p>
                <p class="text-sm text-text-body leading-relaxed">{c.problem}</p>
              </div>
              <div class="rounded-xl bg-blue-50/80 border border-blue-100 p-4">
                <p class="text-xs font-black tracking-wide uppercase text-blue-600 mb-1.5">Service</p>
                <p class="text-sm font-black leading-relaxed text-text-primary">{c.service}</p>
              </div>
              <div class="rounded-xl bg-amber-50/90 border border-amber-100 p-4">
                <p class="text-xs font-black tracking-wide uppercase text-amber-700 mb-1.5">Outcome</p>
                <p class="text-sm text-text-body leading-relaxed">{c.outcome}</p>
              </div>
            </div>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2">
              {c.tags.map((tag) => (
                <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-bold bg-surface-alt text-text-secondary border border-border">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- 業種別実績 -->
    <div class="mt-12 md:mt-16 animate-on-scroll">
      <h3 class="text-lg font-bold text-white text-center mb-6">
        業種別の支援実績<span class="text-accent-400">（50社以上）</span>
      </h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 max-w-4xl mx-auto">
        {industryStats.map((s) => (
          <div class="text-center p-3 rounded-xl bg-white/5 border border-white/10">
            <p class="text-lg font-bold text-accent-400">{s.count}</p>
            <p class="text-xs text-white/50 mt-0.5">{s.label}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- 対応業種タグ -->
    <div class="mt-8 animate-on-scroll">
      <p class="text-sm text-white/40 text-center mb-3">対応している業種の一例</p>
      <div class="flex flex-wrap justify-center gap-2 max-w-3xl mx-auto">
        {industries.map((ind) => (
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-white/8 text-white/60 border border-white/10">
            {ind}
          </span>
        ))}
      </div>
      <p class="text-xs text-white/30 text-center mt-3">上記以外の業種もお気軽にご相談ください</p>
    </div>
  </div>
</section>
